<resources xmlns:tools="http://schemas.android.com/tools">
    <!--
      Dark variant of the base theme. Color values come from values-night/colors.xml
      via the same @color names, so only the window light-bar flags differ from the
      light theme. Redefining the full style is required because resource qualifier
      resolution replaces (does not merge) the style for night configuration.
    -->
    <style name="Base.Theme.AppLockPhotoValut" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_container</item>
        <item name="colorOnPrimaryContainer">@color/primary_light</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>

        <!-- App-wide Inter typeface (weight-mapped family). -->
        <item name="android:fontFamily">@font/inter</item>
        <item name="fontFamily">@font/inter</item>

        <!-- Default TextView style: tight padding like the home screen (applies to
             every plain TextView that doesn't set its own style). -->
        <item name="android:textViewStyle">@style/Widget.App.TextView</item>

        <!-- Semantic text colors (DayNight via @color names → dark values). -->
        <item name="colorTextPrimary">@color/text_primary</item>
        <item name="colorTextSecondary">@color/text_secondary</item>
        <item name="colorTextTertiary">@color/text_tertiary</item>
        <item name="colorTextInverse">@color/text_inverse</item>
        <item name="colorTextError">@color/text_error</item>
        <item name="colorTextSuccess">@color/text_success</item>
        <item name="colorTextWarning">@color/text_warning</item>
    </style>
</resources>
