<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="@dimen/space_m"
    android:paddingBottom="@dimen/space_l">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/screen_padding"
        android:layout_marginBottom="@dimen/space_s"
        android:text="@string/import_title"
        android:textAppearance="@style/TextAppearance.App.Title" />

    <LinearLayout
        android:id="@+id/rowImportPhotos"
        style="@style/SettingsRow">

        <ImageView style="@style/SettingsRowIcon" android:src="@drawable/ic_photo" app:tint="@color/primary" />

        <TextView
            style="@style/SettingsRowTitle"
            android:layout_marginStart="@dimen/space_m"
            android:text="@string/import_option_photos" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/rowImportVideos"
        style="@style/SettingsRow">

        <ImageView style="@style/SettingsRowIcon" android:src="@drawable/ic_video" app:tint="@color/primary" />

        <TextView
            style="@style/SettingsRowTitle"
            android:layout_marginStart="@dimen/space_m"
            android:text="@string/import_option_videos" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/rowImportBoth"
        style="@style/SettingsRow">

        <ImageView style="@style/SettingsRowIcon" android:src="@drawable/ic_add" app:tint="@color/primary" />

        <TextView
            style="@style/SettingsRowTitle"
            android:layout_marginStart="@dimen/space_m"
            android:text="@string/import_option_both" />
    </LinearLayout>
</LinearLayout>
