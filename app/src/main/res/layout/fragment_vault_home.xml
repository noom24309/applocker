<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="18dp"
            android:paddingEnd="20dp"
            android:paddingBottom="20dp">

            <!-- ===== Header ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter_bold"
                            android:text="@string/lv_brand_a"
                            android:textColor="@color/home_title"
                            android:textSize="26sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="7dp"
                            android:fontFamily="@font/inter_bold"
                            android:text="@string/lv_brand_b"
                            android:textColor="@color/home_primary"
                            android:textSize="26sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:fontFamily="@font/inter_medium"
                        android:text="@string/lv_vault_subtitle"
                        android:textColor="@color/home_subtitle"
                        android:textSize="13sp" />
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/btnBell"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_lv_circle_light"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="21dp"
                        android:layout_height="21dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_bell"
                        app:tint="@color/home_primary" />
                </FrameLayout>
            </LinearLayout>

            <!-- ===== Vault is Safe card ===== -->
            <LinearLayout
                android:id="@+id/vaultSafeCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_vault_safe"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <FrameLayout
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:background="@drawable/bg_lv_icon_tile"
                    android:backgroundTint="@color/home_primary">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_shield"
                        app:tint="@color/white" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvSafeTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_semi"
                        android:text="@string/lv_vault_safe_title"
                        android:textColor="@color/home_title"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvSafeSub"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/inter_medium"
                        android:text="@string/lv_vault_safe_sub"
                        android:textColor="@color/home_subtitle"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/learnMore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/inter_semi"
                        android:text="@string/lv_vault_learn_more"
                        android:textColor="@color/home_primary"
                        android:textSize="12.5sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="66dp"
                    android:layout_height="66dp">

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/storageRing"
                        android:layout_width="65dp"
                        android:layout_height="65dp"
                        android:indeterminate="false"
                        android:max="100"
                        android:progress="0"
                        app:indicatorColor="@color/home_primary"
                        app:indicatorSize="62dp"
                        app:trackColor="#D9DAF0"
                        app:trackCornerRadius="8dp"
                        app:trackThickness="4dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:orientation="vertical"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <TextView
                            android:id="@+id/tvStoragePercent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter_bold"
                            android:textColor="@color/home_title"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            tools:text="78%" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter_medium"
                            android:text="@string/lv_vault_used"
                            android:textColor="@color/home_subtitle"
                            android:textSize="9sp" />
                    </LinearLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </LinearLayout>

            <!-- ===== Quick actions ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/actionImportPhotos"
                    style="@style/LvQuickAction">
                    <FrameLayout style="@style/LvQuickTile" android:backgroundTint="@color/home_primary">
                        <ImageView style="@style/LvQuickIcon" android:src="@drawable/ic_photo" />
                    </FrameLayout>
                    <TextView style="@style/LvQuickLabel" android:text="@string/lv_vault_import_photos" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/actionImportVideos"
                    style="@style/LvQuickAction">
                    <FrameLayout style="@style/LvQuickTile" android:backgroundTint="@color/accent_blue">
                        <ImageView style="@style/LvQuickIcon" android:src="@drawable/ic_video" />
                    </FrameLayout>
                    <TextView style="@style/LvQuickLabel" android:text="@string/lv_vault_import_videos" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/actionNewAlbum"
                    style="@style/LvQuickAction">
                    <FrameLayout style="@style/LvQuickTile" android:backgroundTint="@color/accent_red">
                        <ImageView style="@style/LvQuickIcon" android:src="@drawable/ic_album" />
                    </FrameLayout>
                    <TextView style="@style/LvQuickLabel" android:text="@string/lv_vault_new_album" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/actionSettings"
                    style="@style/LvQuickAction">
                    <FrameLayout style="@style/LvQuickTile" android:backgroundTint="@color/accent_amber">
                        <ImageView style="@style/LvQuickIcon" android:src="@drawable/ic_lock" />
                    </FrameLayout>
                    <TextView style="@style/LvQuickLabel" android:text="@string/lv_vault_settings" />
                </LinearLayout>
            </LinearLayout>

            <!-- ===== Albums ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/inter_semi"
                    android:text="@string/lv_vault_albums"
                    android:textColor="@color/home_title"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnAlbumsViewAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="@font/inter_semi"
                    android:padding="4dp"
                    android:text="@string/lv_view_all"
                    android:textColor="@color/home_primary"
                    android:textSize="13sp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerAlbums"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_marginTop="12dp"
                android:clipToPadding="false"
                android:orientation="horizontal"
                android:overScrollMode="never"
                android:scrollbars="none"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_vault_album" />

            <!-- ===== Recent Media ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/inter_semi"
                    android:text="@string/lv_vault_recent"
                    android:textColor="@color/home_title"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnRecentViewAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="@font/inter_semi"
                    android:padding="4dp"
                    android:text="@string/lv_view_all"
                    android:textColor="@color/home_primary"
                    android:textSize="13sp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerRecent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="9dp"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="4"
                tools:itemCount="8"
                tools:listitem="@layout/item_vault_recent" />

            <TextView
                android:id="@+id/tvRecentEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/inter_medium"
                android:gravity="center"
                android:padding="16dp"
                android:text="@string/lv_vault_recent_empty"
                android:textColor="@color/home_subtitle"
                android:textSize="13sp"
                android:visibility="gone" />

            <!-- ===== Protection banner ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_vault_banner"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <FrameLayout
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_lv_icon_tile"
                    android:backgroundTint="#CBF0DA">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_shield"
                        app:tint="@color/home_success" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_semi"
                        android:text="@string/lv_vault_protected_title"
                        android:textColor="@color/home_title"
                        android:textSize="13.5sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:fontFamily="@font/inter_medium"
                        android:text="@string/lv_vault_protected_sub"
                        android:textColor="@color/home_subtitle"
                        android:textSize="11.5sp" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/bannerCheckHealth"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:text="@string/lv_vault_check_health"
                    android:textAllCaps="false"
                    android:textColor="@color/home_success"
                    android:textSize="12sp"
                    app:cornerRadius="10dp"
                    app:strokeColor="@color/home_success" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ===== Bottom Navigation ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_lv_bottom_nav"
        android:elevation="14dp"
        android:orientation="horizontal"
        android:paddingTop="8dp"
        android:paddingBottom="10dp">

        <LinearLayout
            android:id="@+id/navHome"
            style="@style/LvNavTab">
            <View style="@style/LvNavIndicator" android:visibility="invisible" />
            <ImageView android:id="@+id/navHomeIcon" style="@style/LvNavIcon" android:src="@drawable/ic_home" app:tint="@color/home_system_icon" />
            <TextView android:id="@+id/navHomeLabel" style="@style/LvNavLabel" android:text="@string/lv_nav_home" android:textColor="@color/home_system_icon" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navVault"
            style="@style/LvNavTab">
            <View style="@style/LvNavIndicator" android:backgroundTint="@color/home_primary" />
            <ImageView android:id="@+id/navVaultIcon" style="@style/LvNavIcon" android:src="@drawable/ic_vault" app:tint="@color/home_primary" />
            <TextView android:id="@+id/navVaultLabel" style="@style/LvNavLabel" android:text="@string/lv_nav_vault" android:textColor="@color/home_primary" android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navTools"
            style="@style/LvNavTab">
            <View style="@style/LvNavIndicator" android:visibility="invisible" />
            <ImageView android:id="@+id/navToolsIcon" style="@style/LvNavIcon" android:src="@drawable/ic_tools" app:tint="@color/home_system_icon" />
            <TextView android:id="@+id/navToolsLabel" style="@style/LvNavLabel" android:text="@string/lv_nav_tools" android:textColor="@color/home_system_icon" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
