<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:title="@string/vault_title"
        app:titleTextColor="@color/text_primary" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_padding"
            android:paddingTop="@dimen/space_s"
            android:paddingEnd="@dimen/screen_padding"
            android:paddingBottom="@dimen/space_l">

            <TextView
                android:id="@+id/tvStorageUsed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.App.Body"
                tools:text="12.5 MB used"
                xmlns:tools="http://schemas.android.com/tools" />

            <TextView
                android:id="@+id/tvEncryptionStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_s"
                android:drawablePadding="@dimen/space_s"
                android:gravity="center_vertical"
                android:text="@string/vault_encrypted_status"
                android:textAppearance="@style/TextAppearance.App.Body"
                android:textColor="@color/primary"
                app:drawableStartCompat="@drawable/ic_lock" />

            <!-- Row 1: Photos / Videos -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_m"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPhotos"
                    style="@style/Widget.App.Card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/space_s"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true">

                    <include layout="@layout/view_stat_content" android:id="@+id/statPhotos" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardVideos"
                    style="@style/Widget.App.Card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_s"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true">

                    <include layout="@layout/view_stat_content" android:id="@+id/statVideos" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Row 2: Albums / Favorites -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_m"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAlbums"
                    style="@style/Widget.App.Card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/space_s"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true">

                    <include layout="@layout/view_stat_content" android:id="@+id/statAlbums" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardFavorites"
                    style="@style/Widget.App.Card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_s"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true">

                    <include layout="@layout/view_stat_content" android:id="@+id/statFavorites" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Row 3: Recently Imported / Recycle Bin -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_m"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardRecent"
                    style="@style/Widget.App.Card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/space_s"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true">

                    <include layout="@layout/view_stat_content" android:id="@+id/statRecent" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardRecycleBin"
                    style="@style/Widget.App.Card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_s"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true">

                    <include layout="@layout/view_stat_content" android:id="@+id/statRecycleBin" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnImportPhotos"
                style="@style/Widget.App.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_l"
                app:icon="@drawable/ic_photo"
                android:text="@string/vault_import_photos" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnImportVideos"
                style="@style/Widget.App.Button.Outline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_s"
                app:icon="@drawable/ic_video"
                android:text="@string/vault_import_videos" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCreateAlbum"
                style="@style/Widget.App.Button.Text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_s"
                app:icon="@drawable/ic_add"
                android:text="@string/vault_create_album" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
