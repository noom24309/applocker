<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:title="@string/applock_title"
        app:titleTextColor="@color/text_primary" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_padding"
            android:paddingTop="@dimen/space_s"
            android:paddingEnd="@dimen/screen_padding"
            android:paddingBottom="@dimen/space_l">

            <!-- Status card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.App.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/space_m">

                    <FrameLayout
                        android:layout_width="@dimen/card_icon_size"
                        android:layout_height="@dimen/card_icon_size"
                        android:background="@drawable/bg_icon_container">

                        <ImageView
                            android:id="@+id/statusIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:contentDescription="@string/cd_card_icon"
                            android:src="@drawable/ic_shield"
                            app:tint="@color/primary" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_m"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_heading"
                            android:textStyle="bold"
                            tools:text="Protection active" />

                        <TextView
                            android:id="@+id/tvStatusDesc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textAppearance="@style/TextAppearance.App.Body"
                            tools:text="3 apps locked" />
                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/masterSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Setup required banner -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCompleteSetup"
                style="@style/Widget.App.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_m"
                android:text="@string/applock_complete_setup"
                android:visibility="gone"
                tools:visibility="visible" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStart"
                style="@style/Widget.App.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_m"
                android:text="@string/applock_start_protection"
                android:visibility="gone"
                tools:visibility="visible" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStop"
                style="@style/Widget.App.Button.Outline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_m"
                android:text="@string/applock_stop_protection"
                android:visibility="gone"
                tools:visibility="visible" />

            <!-- Manage locked apps -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardManageApps"
                style="@style/Widget.App.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_m"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout style="@style/SettingsRow">

                    <ImageView
                        style="@style/SettingsRowIcon"
                        android:src="@drawable/ic_lock"
                        app:tint="@color/primary" />

                    <LinearLayout style="@style/SettingsRowText">

                        <TextView
                            style="@style/SettingsRowTitle"
                            android:text="@string/applock_manage_apps" />

                        <TextView
                            android:id="@+id/tvLockedCount"
                            style="@style/SettingsRowDesc"
                            tools:text="3 apps locked" />
                    </LinearLayout>

                    <ImageView
                        style="@style/SettingsRowTrailingIcon"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- App Lock settings -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSettings"
                style="@style/Widget.App.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_m"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout style="@style/SettingsRow">

                    <ImageView
                        style="@style/SettingsRowIcon"
                        android:src="@drawable/ic_settings"
                        app:tint="@color/primary" />

                    <LinearLayout style="@style/SettingsRowText">

                        <TextView
                            style="@style/SettingsRowTitle"
                            android:text="@string/applock_settings_title" />

                        <TextView
                            style="@style/SettingsRowDesc"
                            android:text="@string/applock_settings_desc" />
                    </LinearLayout>

                    <ImageView
                        style="@style/SettingsRowTrailingIcon"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Local stats (today) -->
            <TextView style="@style/SettingsSectionHeader" android:text="@string/applock_stats_title" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.App.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_m">

                    <TextView android:id="@+id/tvStatUnlocks" style="@style/TroubleshootRow"
                        android:drawablePadding="0dp" tools:text="Unlocks today: 3" />
                    <TextView android:id="@+id/tvStatFailed" style="@style/TroubleshootRow"
                        android:drawablePadding="0dp" tools:text="Failed attempts: 0" />
                    <TextView android:id="@+id/tvStatOpens" style="@style/TroubleshootRow"
                        android:drawablePadding="0dp" tools:text="Locked app opens: 5" />
                    <TextView android:id="@+id/tvStatProtection" style="@style/TroubleshootRow"
                        android:drawablePadding="0dp" tools:text="Protection active: 2h 10m" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_s"
                        android:text="@string/applock_stats_local_note"
                        android:textColor="@color/text_tertiary"
                        android:textSize="@dimen/text_caption" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_m"
                android:text="@string/applock_usage_privacy"
                android:textColor="@color/text_tertiary"
                android:textSize="@dimen/text_caption" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
