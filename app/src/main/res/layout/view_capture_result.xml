<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_camera_result_panel"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="16dp"
    android:paddingEnd="16dp"
    android:paddingBottom="24dp">

    <TextView
        android:id="@+id/resultTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/camera_saved_to_vault"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:weightSum="5">

        <LinearLayout
            android:id="@+id/actionView"
            style="@style/CaptureResultAction">

            <ImageView
                style="@style/CaptureResultActionIcon"
                android:src="@drawable/ic_play_circle" />

            <TextView
                style="@style/CaptureResultActionLabel"
                android:text="@string/camera_action_view" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/actionAgain"
            style="@style/CaptureResultAction">

            <ImageView
                style="@style/CaptureResultActionIcon"
                android:src="@drawable/ic_camera_flip" />

            <TextView
                style="@style/CaptureResultActionLabel"
                android:text="@string/camera_action_again" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/actionMove"
            style="@style/CaptureResultAction">

            <ImageView
                style="@style/CaptureResultActionIcon"
                android:src="@drawable/ic_add" />

            <TextView
                style="@style/CaptureResultActionLabel"
                android:text="@string/camera_action_move" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/actionDelete"
            style="@style/CaptureResultAction">

            <ImageView
                style="@style/CaptureResultActionIcon"
                android:src="@drawable/ic_delete" />

            <TextView
                style="@style/CaptureResultActionLabel"
                android:text="@string/camera_action_delete" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/actionDone"
            style="@style/CaptureResultAction">

            <ImageView
                style="@style/CaptureResultActionIcon"
                android:src="@drawable/ic_check_circle" />

            <TextView
                style="@style/CaptureResultActionLabel"
                android:text="@string/camera_action_done" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
