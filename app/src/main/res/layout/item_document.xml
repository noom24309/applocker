<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.App.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/screen_padding"
    android:layout_marginTop="@dimen/space_s"
    android:layout_marginEnd="@dimen/screen_padding"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/home_card"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/home_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/space_m">

        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_lv_icon_tile"
            android:backgroundTint="@color/home_tile_purple">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_document"
                app:tint="@color/home_primary" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/docName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="middle"
                android:maxLines="1"
                style="@style/TextAppearance.App.SemiBold"
                android:textColor="@color/home_title"
                android:textSize="15sp"
                tools:text="Passport_scan.pdf" />

            <TextView
                android:id="@+id/docMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                style="@style/TextAppearance.App.Medium"
                android:textColor="@color/home_subtitle"
                android:textSize="12.5sp"
                tools:text="PDF · 2.4 MB · Today" />
        </LinearLayout>

        <ImageView
            android:id="@+id/docFavorite"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="@dimen/space_s"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/action_favorite"
            android:src="@drawable/ic_favorite_border"
            app:tint="@color/home_primary" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
