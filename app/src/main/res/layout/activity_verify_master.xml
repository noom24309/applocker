<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="@dimen/screen_padding"
    android:paddingTop="@dimen/space_xxl"
    android:paddingEnd="@dimen/screen_padding"
    android:paddingBottom="@dimen/screen_padding">

    <TextView
        android:id="@+id/titlePin"
        android:layout_width="wrap_content"
        style="@style/TextAppearance.App.Bold"
        android:layout_height="wrap_content"
        android:text="@string/verify_title"
        android:textAppearance="@style/TextAppearance.App.Title" />

    <TextView
        android:id="@+id/subtitlePin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_s"
        style="@style/TextAppearance.App.Medium"
        android:text="@string/verify_subtitle_pin"
        android:textAppearance="@style/TextAppearance.App.Body" />

    <TextView
        android:id="@+id/errorPin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_m"
        android:gravity="center"
        android:textColor="@color/accent_red"
        android:textSize="@dimen/text_caption"
        android:visibility="invisible"
        tools:text="Incorrect. Try again." />

    <LinearLayout
        android:id="@+id/pinGroup"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/pinDotsContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xxl"
            android:gravity="center"
            android:orientation="horizontal" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <include layout="@layout/view_pin_keypad" />
    </LinearLayout>

    <app.lock.photo.valut.core.ui.PatternLockView
        android:id="@+id/patternView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/space_m"
        android:layout_weight="1"
        android:contentDescription="@string/cd_pattern"
        android:visibility="gone" />

</LinearLayout>
