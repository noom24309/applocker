<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_bg"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <!-- ===== Header ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_title"
                    android:textColor="@color/home_title"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    style="@style/TextAppearance.App.Medium"
                    android:text="@string/settings_subtitle"
                    android:textColor="@color/home_subtitle"
                    android:textSize="13sp" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_lv_circle_light">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_account"
                    app:tint="@color/home_primary" />
            </FrameLayout>
        </LinearLayout>

        <!-- ===== Security Status ===== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSecurityStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/primary_container"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <FrameLayout
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:background="@drawable/bg_lv_icon_tile"
                    android:backgroundTint="@color/primary">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_shield"
                        app:tint="@color/white" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_security_status"
                        android:textColor="@color/home_title"
                        android:textSize="16sp"
                        android:fontFamily="@font/inter_semi" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        style="@style/TextAppearance.App.Medium"
                        android:text="@string/settings_security_status_desc"
                        android:textColor="@color/home_subtitle"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_marginEnd="5dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_check_circle"
                            app:tint="@color/home_success" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/TextAppearance.App.Medium"
                            android:text="@string/settings_security_status_active"
                            android:textColor="@color/home_success"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center_vertical"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="@color/home_primary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== Security ===== -->
        <TextView
            style="@style/SettingsSectionHeader"
            android:text="@string/settings_security" />

        <com.google.android.material.card.MaterialCardView style="@style/SettingsCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Change PIN -->
                <LinearLayout
                    android:id="@+id/rowChangePin"
                    style="@style/SettingsRow">

                    <FrameLayout
                        style="@style/SettingsIconTile"
                        android:backgroundTint="@color/home_tile_purple">

                        <ImageView
                            style="@style/SettingsIconImg"
                            android:src="@drawable/ic_lock"
                            app:tint="@color/home_primary" />
                    </FrameLayout>

                    <LinearLayout style="@style/SettingsRowText">

                        <TextView
                            style="@style/SettingsRowTitle"
                            android:text="@string/settings_change_pin" />

                        <TextView
                            style="@style/SettingsRowDesc"
                            android:text="@string/settings_change_pin_desc_alt" />
                    </LinearLayout>

                    <ImageView
                        style="@style/SettingsRowTrailingIcon"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/home_hint" />
                </LinearLayout>

                <View style="@style/SettingsDivider" />

                <!-- Change Pattern -->
                <LinearLayout
                    android:id="@+id/rowChangePattern"
                    style="@style/SettingsRow">

                    <FrameLayout
                        style="@style/SettingsIconTile"
                        android:backgroundTint="@color/home_tile_purple">

                        <ImageView
                            style="@style/SettingsIconImg"
                            android:src="@drawable/ic_pattern"
                            app:tint="@color/home_primary" />
                    </FrameLayout>

                    <LinearLayout style="@style/SettingsRowText">

                        <TextView
                            style="@style/SettingsRowTitle"
                            android:text="@string/settings_change_pattern" />

                        <TextView
                            style="@style/SettingsRowDesc"
                            android:text="@string/settings_change_pattern_desc" />
                    </LinearLayout>

                    <ImageView
                        style="@style/SettingsRowTrailingIcon"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/home_hint" />
                </LinearLayout>

                <View style="@style/SettingsDivider" />

                <!-- Biometric -->
                <LinearLayout
                    android:id="@+id/rowBiometric"
                    style="@style/SettingsRow">

                    <FrameLayout
                        style="@style/SettingsIconTile"
                        android:backgroundTint="@color/home_tile_blue">

                        <ImageView
                            style="@style/SettingsIconImg"
                            android:src="@drawable/ic_fingerprint"
                            app:tint="@color/home_info" />
                    </FrameLayout>

                    <LinearLayout style="@style/SettingsRowText">

                        <TextView
                            style="@style/SettingsRowTitle"
                            android:text="@string/settings_biometric_alt" />

                        <TextView
                            style="@style/SettingsRowDesc"
                            android:text="@string/settings_biometric_desc_alt" />
                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchBiometric"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="false"
                        android:focusable="false" />
                </LinearLayout>

                <View style="@style/SettingsDivider" />

                <!-- Auto Lock -->
                <LinearLayout
                    android:id="@+id/rowAutoLock"
                    style="@style/SettingsRow">

                    <FrameLayout
                        style="@style/SettingsIconTile"
                        android:backgroundTint="@color/home_tile_teal">

                        <ImageView
                            style="@style/SettingsIconImg"
                            android:src="@drawable/ic_clock"
                            app:tint="@color/home_teal" />
                    </FrameLayout>

                    <LinearLayout style="@style/SettingsRowText">

                        <TextView
                            style="@style/SettingsRowTitle"
                            android:text="@string/settings_auto_lock" />

                        <TextView
                            style="@style/SettingsRowDesc"
                            android:text="@string/settings_auto_lock_desc_alt" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvAutoLockValue"
                        style="@style/SettingsRowValue"
                        android:textColor="@color/home_primary"
                        tools:text="5 minutes" />

                    <ImageView
                        style="@style/SettingsRowTrailingIcon"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/home_hint" />
                </LinearLayout>

                <View style="@style/SettingsDivider" />

                <!-- Wrong Attempt Protection -->
                <LinearLayout
                    android:id="@+id/rowWrongAttempt"
                    style="@style/SettingsRow">

                    <FrameLayout
                        style="@style/SettingsIconTile"
                        android:backgroundTint="@color/home_tile_pink">

                        <ImageView
                            style="@style/SettingsIconImg"
                            android:src="@drawable/ic_intruder"
                            app:tint="@color/accent_red" />
                    </FrameLayout>

                    <LinearLayout style="@style/SettingsRowText">

                        <TextView
                            style="@style/SettingsRowTitle"
                            android:text="@string/settings_wrong_attempt" />

                        <TextView
                            style="@style/SettingsRowDesc"
                            android:text="@string/settings_wrong_attempt_desc_alt" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvWrongAttemptValue"
                        style="@style/SettingsRowValue"
                        android:textColor="@color/home_primary"
                        tools:text="5 attempts" />

                    <ImageView
                        style="@style/SettingsRowTrailingIcon"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/home_hint" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== App Lock ===== -->
        <TextView
            style="@style/SettingsSectionHeader"
            android:text="@string/settings_section_app_lock" />

        <com.google.android.material.card.MaterialCardView style="@style/SettingsCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- App Lock Settings -->
                <LinearLayout
                    android:id="@+id/rowAppLockSettings"
                    style="@style/SettingsRow">

                    <FrameLayout
                        style="@style/SettingsIconTile"
                        android:backgroundTint="@color/home_tile_purple">

                        <ImageView
                            style="@style/SettingsIconImg"
                            android:src="@drawable/ic_apps"
                            app:tint="@color/home_primary" />
                    </FrameLayout>

                    <LinearLayout style="@style/SettingsRowText">

                        <TextView
                            style="@style/SettingsRowTitle"
                            android:text="@string/settings_app_lock_settings" />

                        <TextView
                            style="@style/SettingsRowDesc"
                            android:text="@string/settings_app_lock_settings_desc" />
                    </LinearLayout>

                    <ImageView
                        style="@style/SettingsRowTrailingIcon"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/home_hint" />
                </LinearLayout>

                <View style="@style/SettingsDivider" />

                <!-- Lock Screen Overlay -->
                <LinearLayout
                    android:id="@+id/rowLockOverlay"
                    style="@style/SettingsRow">

                    <FrameLayout
                        style="@style/SettingsIconTile"
                        android:backgroundTint="@color/home_tile_blue">

                        <ImageView
                            style="@style/SettingsIconImg"
                            android:src="@drawable/ic_layers"
                            app:tint="@color/home_info" />
                    </FrameLayout>

                    <LinearLayout style="@style/SettingsRowText">

                        <TextView
                            style="@style/SettingsRowTitle"
                            android:text="@string/settings_lock_overlay" />

                        <TextView
                            style="@style/SettingsRowDesc"
                            android:text="@string/settings_lock_overlay_desc" />
                    </LinearLayout>

                    <ImageView
                        style="@style/SettingsRowTrailingIcon"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/home_hint" />
                </LinearLayout>

                <View style="@style/SettingsDivider" />

                <!-- Disguise Mode -->
                <LinearLayout
                    android:id="@+id/rowDisguise"
                    style="@style/SettingsRow">

                    <FrameLayout
                        style="@style/SettingsIconTile"
                        android:backgroundTint="@color/home_tile_amber">

                        <ImageView
                            style="@style/SettingsIconImg"
                            android:src="@drawable/ic_calculator"
                            app:tint="@color/accent_amber" />
                    </FrameLayout>

                    <LinearLayout style="@style/SettingsRowText">

                        <TextView
                            style="@style/SettingsRowTitle"
                            android:text="@string/settings_disguise" />

                        <TextView
                            style="@style/SettingsRowDesc"
                            android:text="@string/settings_disguise_desc" />
                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchDisguise"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="false"
                        android:focusable="false" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== Preferences ===== -->
        <TextView
            style="@style/SettingsSectionHeader"
            android:text="@string/settings_section_preferences" />

        <com.google.android.material.card.MaterialCardView style="@style/SettingsCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Notifications -->
                <LinearLayout
                    android:id="@+id/rowNotifications"
                    style="@style/SettingsRow">

                    <FrameLayout
                        style="@style/SettingsIconTile"
                        android:backgroundTint="@color/home_tile_purple">

                        <ImageView
                            style="@style/SettingsIconImg"
                            android:src="@drawable/ic_bell"
                            app:tint="@color/home_primary" />
                    </FrameLayout>

                    <LinearLayout style="@style/SettingsRowText">

                        <TextView
                            style="@style/SettingsRowTitle"
                            android:text="@string/settings_notifications" />

                        <TextView
                            style="@style/SettingsRowDesc"
                            android:text="@string/settings_notifications_desc" />
                    </LinearLayout>

                    <ImageView
                        style="@style/SettingsRowTrailingIcon"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/home_hint" />
                </LinearLayout>

                <View style="@style/SettingsDivider" />

                <!-- Language -->
                <LinearLayout
                    android:id="@+id/rowLanguage"
                    style="@style/SettingsRow">

                    <FrameLayout
                        style="@style/SettingsIconTile"
                        android:backgroundTint="@color/home_tile_teal">

                        <ImageView
                            style="@style/SettingsIconImg"
                            android:src="@drawable/ic_globe"
                            app:tint="@color/home_teal" />
                    </FrameLayout>

                    <LinearLayout style="@style/SettingsRowText">

                        <TextView
                            style="@style/SettingsRowTitle"
                            android:text="@string/settings_language" />

                        <TextView
                            style="@style/SettingsRowDesc"
                            android:text="@string/settings_language_desc" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvLanguageValue"
                        style="@style/SettingsRowValue"
                        android:textColor="@color/home_primary"
                        android:text="@string/settings_language_default" />

                    <ImageView
                        style="@style/SettingsRowTrailingIcon"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/home_hint" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== More ===== -->
        <TextView
            style="@style/SettingsSectionHeader"
            android:text="@string/settings_section_more" />

        <com.google.android.material.card.MaterialCardView style="@style/SettingsCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Privacy Policy -->
                <LinearLayout
                    android:id="@+id/rowPrivacy"
                    style="@style/SettingsRow">

                    <FrameLayout
                        style="@style/SettingsIconTile"
                        android:backgroundTint="@color/home_tile_purple">

                        <ImageView
                            style="@style/SettingsIconImg"
                            android:src="@drawable/ic_shield"
                            app:tint="@color/home_primary" />
                    </FrameLayout>

                    <LinearLayout style="@style/SettingsRowText">

                        <TextView
                            style="@style/SettingsRowTitle"
                            android:text="@string/settings_privacy_policy" />

                        <TextView
                            style="@style/SettingsRowDesc"
                            android:text="@string/settings_privacy_policy_desc" />
                    </LinearLayout>

                    <ImageView
                        style="@style/SettingsRowTrailingIcon"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/home_hint" />
                </LinearLayout>

                <View style="@style/SettingsDivider" />

                <!-- About -->
                <LinearLayout
                    android:id="@+id/rowAbout"
                    style="@style/SettingsRow">

                    <FrameLayout
                        style="@style/SettingsIconTile"
                        android:backgroundTint="@color/home_tile_blue">

                        <ImageView
                            style="@style/SettingsIconImg"
                            android:src="@drawable/ic_info"
                            app:tint="@color/home_info" />
                    </FrameLayout>

                    <LinearLayout style="@style/SettingsRowText">

                        <TextView
                            style="@style/SettingsRowTitle"
                            android:text="@string/settings_about_app" />

                        <TextView
                            android:id="@+id/tvAppVersion"
                            style="@style/SettingsRowDesc"
                            android:text="@string/settings_about_app_desc" />
                    </LinearLayout>

                    <ImageView
                        style="@style/SettingsRowTrailingIcon"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/home_hint" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
