<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="6dp"
            android:padding="8dp"
            android:src="@drawable/ic_arrow_back"
            android:visibility="visible"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/text_primary" />


        <TextView
            android:id="@+id/title"
            style="@style/TextAppearance.App.Bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:gravity="center"
            android:text="Enter Notes"
            android:textColor="@color/text_primary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/iv_back"
            app:layout_constraintTop_toTopOf="parent" />


    </androidx.constraintlayout.widget.ConstraintLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_padding"
        android:paddingTop="@dimen/space_s"
        android:paddingEnd="@dimen/screen_padding">

        <!-- Encrypted pill -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_note_encrypted_pill"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingTop="5dp"
            android:paddingEnd="12dp"
            android:paddingBottom="5dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:contentDescription="@string/notes_encrypted_badge"
                android:src="@drawable/ic_lock"
                app:tint="@color/primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:fontFamily="@font/inter_semi"
                android:includeFontPadding="false"
                android:letterSpacing="0.01"
                android:text="@string/notes_encrypted_badge"
                android:textColor="@color/primary"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Title -->
        <EditText
            android:id="@+id/titleInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_m"
            android:background="@null"
            android:fontFamily="@font/inter_bold"
            android:hint="@string/notes_title_hint"
            android:importantForAutofill="no"
            android:includeFontPadding="false"
            android:inputType="textCapSentences|textMultiLine"
            android:maxLines="3"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_tertiary"
            android:textSize="26sp" />

        <!-- Meta -->
        <TextView
            android:id="@+id/tvMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:fontFamily="@font/inter_medium"
            android:includeFontPadding="false"
            android:textColor="@color/text_tertiary"
            android:textSize="@dimen/text_caption"
            tools:text="0 words · 0 characters" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="@dimen/screen_padding"
        android:layout_marginTop="@dimen/space_m"
        android:layout_marginEnd="@dimen/screen_padding"
        android:background="@color/divider" />

    <!-- ===== Body ===== -->
    <EditText
        android:id="@+id/bodyInput"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@null"
        android:gravity="top"
        android:hint="@string/notes_body_hint"
        android:importantForAutofill="no"
        android:includeFontPadding="false"
        android:inputType="textMultiLine|textCapSentences"
        android:lineSpacingMultiplier="1.5"
        android:paddingStart="@dimen/screen_padding"
        android:paddingTop="@dimen/space_l"
        android:paddingEnd="@dimen/screen_padding"
        android:paddingBottom="@dimen/space_xxl"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_tertiary"
        android:textSize="16sp" />

</LinearLayout>
