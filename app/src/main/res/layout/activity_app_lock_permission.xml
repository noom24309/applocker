<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:title="@string/applock_permission_title"
        app:titleTextColor="@color/text_primary" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_padding"
            android:paddingTop="@dimen/space_s"
            android:paddingEnd="@dimen/screen_padding"
            android:paddingBottom="@dimen/space_l">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/applock_permission_subtitle"
                android:textAppearance="@style/TextAppearance.App.Body" />

            <!-- Usage Access -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.App.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_m">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_m">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="@string/cd_card_icon"
                            android:src="@drawable/ic_shield"
                            app:tint="@color/primary" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/space_m"
                            android:layout_weight="1"
                            android:text="@string/applock_perm_usage_title"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/checkUsage"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="@string/applock_perm_granted"
                            android:src="@drawable/ic_check_circle"
                            android:visibility="gone"
                            app:tint="@color/accent_green" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_s"
                        android:text="@string/applock_perm_usage_desc"
                        android:textAppearance="@style/TextAppearance.App.Body" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnUsage"
                        style="@style/Widget.App.Button.Outline"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_s"
                        android:text="@string/applock_perm_usage_button" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Overlay -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.App.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_m">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_m">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="@string/cd_card_icon"
                            android:src="@drawable/ic_lock"
                            app:tint="@color/primary" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/space_m"
                            android:layout_weight="1"
                            android:text="@string/applock_perm_overlay_title"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/checkOverlay"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="@string/applock_perm_granted"
                            android:src="@drawable/ic_check_circle"
                            android:visibility="gone"
                            app:tint="@color/accent_green" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_s"
                        android:text="@string/applock_perm_overlay_desc"
                        android:textAppearance="@style/TextAppearance.App.Body" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnOverlay"
                        style="@style/Widget.App.Button.Outline"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_s"
                        android:text="@string/applock_perm_overlay_button" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Notification -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.App.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_m">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_m">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="@string/cd_card_icon"
                            android:src="@drawable/ic_intruder"
                            app:tint="@color/primary" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/space_m"
                            android:layout_weight="1"
                            android:text="@string/applock_perm_notification_title"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/checkNotification"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:contentDescription="@string/applock_perm_granted"
                            android:src="@drawable/ic_check_circle"
                            android:visibility="gone"
                            app:tint="@color/accent_green" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_s"
                        android:text="@string/applock_perm_notification_desc"
                        android:textAppearance="@style/TextAppearance.App.Body" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnNotification"
                        style="@style/Widget.App.Button.Outline"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_s"
                        android:text="@string/applock_perm_notification_button" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Privacy note -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_m"
                android:text="@string/applock_usage_privacy"
                android:textColor="@color/text_tertiary"
                android:textSize="@dimen/text_caption" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCheckAgain"
                style="@style/Widget.App.Button.Text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/space_m"
                android:text="@string/applock_perm_check_again" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContinue"
                style="@style/Widget.App.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_s"
                android:enabled="false"
                android:text="@string/continue_label" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
