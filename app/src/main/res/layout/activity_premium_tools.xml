<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_bg">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="16dp"
            android:paddingEnd="20dp"
            android:paddingBottom="24dp">

            <!-- ===== Header ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/lv_brand_a"
                            android:textColor="@color/home_title"
                            android:textSize="26sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="7dp"
                            android:text="@string/lv_brand_b"
                            android:textColor="@color/home_primary"
                            android:textSize="26sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        style="@style/TextAppearance.App.Medium"
                        android:text="@string/tools_header_subtitle"
                        android:textColor="@color/home_subtitle"
                        android:textSize="13sp" />
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/btnSettings"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:background="@drawable/bg_lv_circle_light"
                    android:clickable="true"
                    android:contentDescription="@string/nav_settings"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_settings"
                        app:tint="@color/home_primary" />
                </FrameLayout>
            </LinearLayout>

            <!-- ===== Hero card ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_hero_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="18dp">

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_hero_pill">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_shield"
                        app:tint="@color/white" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tools_hero_title"
                        android:textColor="@color/white"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        style="@style/TextAppearance.App.Medium"
                        android:text="@string/tools_hero_desc"
                        android:textColor="@color/hero_text_muted"
                        android:textSize="12.5sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="62dp"
                        android:layout_height="62dp"
                        android:background="@drawable/bg_hero_ring">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="@string/tools_hero_percent"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        style="@style/TextAppearance.App.Medium"
                        android:text="@string/tools_hero_protected"
                        android:textColor="@color/hero_text_muted"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ===== Cleanup Tools ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="@string/tools_section_cleanup"
                android:textColor="@color/home_title"
                android:textSize="17sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardDuplicates"
                    style="@style/ToolTileCard"
                    android:layout_marginEnd="6dp">

                    <LinearLayout style="@style/ToolTileContent">

                        <FrameLayout
                            style="@style/ToolTileIconBox"
                            android:background="@drawable/bg_tile_purple">

                            <ImageView
                                style="@style/ToolTileIcon"
                                android:src="@drawable/ic_duplicate"
                                app:tint="@color/home_primary" />
                        </FrameLayout>

                        <TextView
                            style="@style/ToolTileTitle"
                            android:text="@string/tools_duplicate_finder" />

                        <TextView
                            style="@style/ToolTileDesc"
                            android:text="@string/tools_duplicate_desc" />

                        <TextView
                            android:id="@+id/tvDuplicatesValue"
                            style="@style/ToolTileValue"
                            android:text="@string/tools_sample_dup_size"
                            android:textColor="@color/home_primary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardLargeFiles"
                    style="@style/ToolTileCard"
                    android:layout_marginStart="6dp">

                    <LinearLayout style="@style/ToolTileContent">

                        <FrameLayout
                            style="@style/ToolTileIconBox"
                            android:background="@drawable/bg_tile_blue">

                            <ImageView
                                style="@style/ToolTileIcon"
                                android:src="@drawable/ic_folder"
                                app:tint="@color/accent_blue" />
                        </FrameLayout>

                        <TextView
                            style="@style/ToolTileTitle"
                            android:text="@string/tools_large_files" />

                        <TextView
                            style="@style/ToolTileDesc"
                            android:text="@string/tools_large_files_desc" />

                        <TextView
                            android:id="@+id/tvLargeFilesValue"
                            style="@style/ToolTileValue"
                            android:text="@string/tools_sample_large_size"
                            android:textColor="@color/accent_blue" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSmartCleanup"
                    style="@style/ToolTileCard"
                    android:layout_marginEnd="6dp">

                    <LinearLayout style="@style/ToolTileContent">

                        <FrameLayout
                            style="@style/ToolTileIconBox"
                            android:background="@drawable/bg_tile_amber">

                            <ImageView
                                style="@style/ToolTileIcon"
                                android:src="@drawable/ic_sparkle"
                                app:tint="@color/accent_amber" />
                        </FrameLayout>

                        <TextView
                            style="@style/ToolTileTitle"
                            android:text="@string/tools_smart_cleanup" />

                        <TextView
                            style="@style/ToolTileDesc"
                            android:text="@string/tools_smart_cleanup_desc" />

                        <TextView
                            android:id="@+id/tvSmartCleanupValue"
                            style="@style/ToolTileValue"
                            android:text="@string/tools_sample_cleanup_size"
                            android:textColor="@color/accent_amber" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardStorage"
                    style="@style/ToolTileCard"
                    android:layout_marginStart="6dp">

                    <LinearLayout style="@style/ToolTileContent">

                        <FrameLayout
                            style="@style/ToolTileIconBox"
                            android:background="@drawable/bg_tile_teal">

                            <ImageView
                                style="@style/ToolTileIcon"
                                android:src="@drawable/ic_pie_chart"
                                app:tint="@color/home_teal" />
                        </FrameLayout>

                        <TextView
                            style="@style/ToolTileTitle"
                            android:text="@string/tools_storage_analyzer" />

                        <TextView
                            style="@style/ToolTileDesc"
                            android:text="@string/tools_storage_analyzer_desc" />

                        <TextView
                            style="@style/ToolTileValue"
                            android:text="@string/tools_view_details"
                            android:textColor="@color/home_teal" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ===== Security & Privacy ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/tools_section_security"
                android:textColor="@color/home_title"
                android:textSize="17sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardHealth"
                    style="@style/ToolTileCard"
                    android:layout_marginEnd="6dp">

                    <LinearLayout style="@style/ToolTileContent">

                        <FrameLayout
                            style="@style/ToolTileIconBox"
                            android:background="@drawable/bg_tile_purple">

                            <ImageView
                                style="@style/ToolTileIcon"
                                android:src="@drawable/ic_shield"
                                app:tint="@color/home_primary" />
                        </FrameLayout>

                        <TextView
                            style="@style/ToolTileTitle"
                            android:text="@string/tools_vault_health" />

                        <TextView
                            style="@style/ToolTileDesc"
                            android:text="@string/tools_vault_health_desc" />

                        <TextView
                            style="@style/ToolTileValue"
                            android:text="@string/tools_status_secure"
                            android:textColor="@color/home_success" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPrivacyScan"
                    style="@style/ToolTileCard"
                    android:layout_marginStart="6dp">

                    <LinearLayout style="@style/ToolTileContent">

                        <FrameLayout
                            style="@style/ToolTileIconBox"
                            android:background="@drawable/bg_tile_blue">

                            <ImageView
                                style="@style/ToolTileIcon"
                                android:src="@drawable/ic_lock"
                                app:tint="@color/accent_blue" />
                        </FrameLayout>

                        <TextView
                            style="@style/ToolTileTitle"
                            android:text="@string/tools_privacy_scan" />

                        <TextView
                            style="@style/ToolTileDesc"
                            android:text="@string/tools_privacy_scan_desc" />

                        <TextView
                            style="@style/ToolTileValue"
                            android:text="@string/tools_status_no_issues"
                            android:textColor="@color/home_success" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPermissions"
                    style="@style/ToolTileCard"
                    android:layout_marginEnd="6dp">

                    <LinearLayout style="@style/ToolTileContent">

                        <FrameLayout
                            style="@style/ToolTileIconBox"
                            android:background="@drawable/bg_tile_green">

                            <ImageView
                                style="@style/ToolTileIcon"
                                android:src="@drawable/ic_key"
                                app:tint="@color/home_success" />
                        </FrameLayout>

                        <TextView
                            style="@style/ToolTileTitle"
                            android:text="@string/tools_permission_manager" />

                        <TextView
                            style="@style/ToolTileDesc"
                            android:text="@string/tools_permission_manager_desc" />

                        <TextView
                            style="@style/ToolTileValue"
                            android:text="@string/tools_status_manage"
                            android:textColor="@color/accent_amber" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSecureDelete"
                    style="@style/ToolTileCard"
                    android:layout_marginStart="6dp">

                    <LinearLayout style="@style/ToolTileContent">

                        <FrameLayout
                            style="@style/ToolTileIconBox"
                            android:background="@drawable/bg_tile_pink">

                            <ImageView
                                style="@style/ToolTileIcon"
                                android:src="@drawable/ic_delete"
                                app:tint="@color/accent_red" />
                        </FrameLayout>

                        <TextView
                            style="@style/ToolTileTitle"
                            android:text="@string/tools_secure_delete" />

                        <TextView
                            style="@style/ToolTileDesc"
                            android:text="@string/tools_secure_delete_desc" />

                        <TextView
                            android:id="@+id/tvSecureDeleteValue"
                            style="@style/ToolTileValue"
                            android:text="@string/tools_sample_delete_count"
                            android:textColor="@color/accent_red" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ===== Optimize card ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_premium_card"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:background="@drawable/bg_hero_pill">

                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_vault"
                            app:tint="@color/white" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/tools_optimize_title"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            style="@style/TextAppearance.App.Medium"
                            android:text="@string/tools_optimize_desc"
                            android:textColor="@color/hero_text_muted"
                            android:textSize="12.5sp" />
                    </LinearLayout>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRunScan"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginTop="16dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:paddingStart="22dp"
                    android:paddingEnd="22dp"
                    android:text="@string/tools_run_smart_scan"
                    android:textAllCaps="false"
                    android:textColor="@color/home_primary"
                    android:textSize="14sp"
                    app:backgroundTint="@color/white"
                    app:cornerRadius="14dp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_lv_bottom_nav"
        app:elevation="12dp"
        app:itemIconTint="@color/nav_item_color"
        app:itemTextColor="@color/nav_item_color"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/bottom_nav_menu"
        tools:ignore="ContentDescription" />

</androidx.constraintlayout.widget.ConstraintLayout>
