<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="8dp">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="6dp"
            android:padding="8dp"
            android:contentDescription="@string/cd_card_icon"
            android:src="@drawable/ic_arrow_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/text_primary" />

        <TextView
            android:id="@+id/title"
            style="@style/TextAppearance.App.Bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:gravity="center"
            android:text="@string/premium_tools_title"
            android:textColor="@color/text_primary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/iv_back"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_padding"
            android:paddingTop="@dimen/space_s"
            android:paddingEnd="@dimen/screen_padding"
            android:paddingBottom="@dimen/space_l">

            <TextView
                style="@style/SettingsSectionHeader"
                android:text="@string/premium_section_private_tools" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardNotes"
                style="@style/Widget.App.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_s"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    style="@style/SettingsRow"
                    android:clickable="false"
                    android:focusable="false">

                    <ImageView
                        style="@style/SettingsRowIcon"
                        android:src="@drawable/ic_note"
                        app:tint="@color/primary" />

                    <LinearLayout style="@style/SettingsRowText">

                        <TextView
                            style="@style/SettingsRowTitle"
                            android:text="@string/notes_title" />

                        <TextView
                            android:id="@+id/notesSubtitle"
                            style="@style/SettingsRowDesc"
                            android:text="@string/notes_subtitle" />
                    </LinearLayout>

                    <TextView
                        style="@style/PremiumBadge"
                        android:text="@string/premium_badge" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDocuments"
                style="@style/Widget.App.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_m"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    style="@style/SettingsRow"
                    android:clickable="false"
                    android:focusable="false">

                    <ImageView
                        style="@style/SettingsRowIcon"
                        android:src="@drawable/ic_document"
                        app:tint="@color/primary" />

                    <LinearLayout style="@style/SettingsRowText">

                        <TextView
                            style="@style/SettingsRowTitle"
                            android:text="@string/documents_title" />

                        <TextView
                            android:id="@+id/documentsSubtitle"
                            style="@style/SettingsRowDesc"
                            android:text="@string/documents_subtitle" />
                    </LinearLayout>

                    <TextView
                        style="@style/PremiumBadge"
                        android:text="@string/premium_badge" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                style="@style/SettingsSectionHeader"
                android:layout_marginTop="@dimen/space_l"
                android:text="@string/premium_section_cleanup" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDuplicates"
                style="@style/Widget.App.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_s"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    style="@style/SettingsRow"
                    android:clickable="false"
                    android:focusable="false">

                    <ImageView
                        style="@style/SettingsRowIcon"
                        android:src="@drawable/ic_photo"
                        app:tint="@color/primary" />

                    <LinearLayout style="@style/SettingsRowText">

                        <TextView
                            style="@style/SettingsRowTitle"
                            android:text="@string/duplicates_title" />

                        <TextView
                            style="@style/SettingsRowDesc"
                            android:text="@string/duplicates_subtitle" />
                    </LinearLayout>

                    <ImageView
                        style="@style/SettingsRowTrailingIcon"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLargeFiles"
                style="@style/Widget.App.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_m"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    style="@style/SettingsRow"
                    android:clickable="false"
                    android:focusable="false">

                    <ImageView
                        style="@style/SettingsRowIcon"
                        android:src="@drawable/ic_video"
                        app:tint="@color/primary" />

                    <LinearLayout style="@style/SettingsRowText">

                        <TextView
                            style="@style/SettingsRowTitle"
                            android:text="@string/large_files_title" />

                        <TextView
                            style="@style/SettingsRowDesc"
                            android:text="@string/large_files_subtitle" />
                    </LinearLayout>

                    <ImageView
                        style="@style/SettingsRowTrailingIcon"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSmartCleanup"
                style="@style/Widget.App.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_m"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    style="@style/SettingsRow"
                    android:clickable="false"
                    android:focusable="false">

                    <ImageView
                        style="@style/SettingsRowIcon"
                        android:src="@drawable/ic_check_circle"
                        app:tint="@color/primary" />

                    <LinearLayout style="@style/SettingsRowText">

                        <TextView
                            style="@style/SettingsRowTitle"
                            android:text="@string/cleanup_title" />

                        <TextView
                            style="@style/SettingsRowDesc"
                            android:text="@string/cleanup_subtitle" />
                    </LinearLayout>

                    <ImageView
                        style="@style/SettingsRowTrailingIcon"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                style="@style/SettingsSectionHeader"
                android:layout_marginTop="@dimen/space_l"
                android:text="@string/premium_section_health" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStorage"
                style="@style/Widget.App.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_s"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    style="@style/SettingsRow"
                    android:clickable="false"
                    android:focusable="false">

                    <ImageView
                        style="@style/SettingsRowIcon"
                        android:src="@drawable/ic_document"
                        app:tint="@color/primary" />

                    <LinearLayout style="@style/SettingsRowText">

                        <TextView
                            style="@style/SettingsRowTitle"
                            android:text="@string/storage_analyzer_title" />

                        <TextView
                            style="@style/SettingsRowDesc"
                            android:text="@string/storage_analyzer_subtitle" />
                    </LinearLayout>

                    <ImageView
                        style="@style/SettingsRowTrailingIcon"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardHealth"
                style="@style/Widget.App.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_m"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    style="@style/SettingsRow"
                    android:clickable="false"
                    android:focusable="false">

                    <ImageView
                        style="@style/SettingsRowIcon"
                        android:src="@drawable/ic_shield"
                        app:tint="@color/primary" />

                    <LinearLayout style="@style/SettingsRowText">

                        <TextView
                            style="@style/SettingsRowTitle"
                            android:text="@string/health_title" />

                        <TextView
                            style="@style/SettingsRowDesc"
                            android:text="@string/health_subtitle" />
                    </LinearLayout>

                    <ImageView
                        style="@style/SettingsRowTrailingIcon"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_l"
                android:text="@string/premium_more_tools_note"
                android:textColor="@color/text_tertiary"
                android:textSize="@dimen/text_caption" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
