<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_bg"
    android:orientation="vertical">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="8dp">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="6dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:contentDescription="@string/cd_card_icon"
            android:src="@drawable/ic_arrow_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/home_title" />

        <TextView
            android:id="@+id/title"
            style="@style/TextAppearance.App.Bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:gravity="center"
            android:text="@string/card_add_title"
            android:textColor="@color/home_title"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/iv_back"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_padding"
            android:paddingTop="@dimen/space_s"
            android:paddingEnd="@dimen/screen_padding"
            android:paddingBottom="@dimen/space_xl">

            <include
                android:id="@+id/preview"
                layout="@layout/item_document_card" />

            <!-- ===== Images section ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_l"
                android:background="@drawable/bg_back"
                android:orientation="vertical"
                android:padding="@dimen/space_m">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_semi"
                    android:text="@string/card_section_images"
                    android:textColor="@color/home_title"
                    android:textSize="14sp" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/frontImageCard"
                    style="@style/Widget.App.Card"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:layout_marginTop="@dimen/space_m"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/home_tile_blue"
                    app:strokeColor="@color/home_border"
                    app:strokeWidth="1dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:id="@+id/frontPreview"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/cd_card_front"
                            android:scaleType="centerCrop" />

                        <LinearLayout
                            android:id="@+id/frontEmpty"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_camera"
                                app:tint="@color/home_info" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_s"
                                android:fontFamily="@font/inter_medium"
                                android:text="@string/card_add_front"
                                android:textColor="@color/home_subtitle"
                                android:textSize="@dimen/text_body" />
                        </LinearLayout>
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/frontReplaceButton"
                    style="@style/Widget.App.Button.Text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/home_primary"
                    android:text="@string/card_replace_image"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/backImageCard"
                    style="@style/Widget.App.Card"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:layout_marginTop="@dimen/space_m"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/home_tile_blue"
                    app:strokeColor="@color/home_border"
                    app:strokeWidth="1dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:id="@+id/backPreview"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/cd_card_back"
                            android:scaleType="centerCrop" />

                        <LinearLayout
                            android:id="@+id/backEmpty"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_camera"
                                app:tint="@color/home_info" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_s"
                                android:fontFamily="@font/inter_medium"
                                android:text="@string/card_add_back"
                                android:textColor="@color/home_subtitle"
                                android:textSize="@dimen/text_body" />
                        </LinearLayout>
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/backRemoveButton"
                    style="@style/Widget.App.Button.Text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/home_primary"
                    android:text="@string/card_remove_image"
                    android:visibility="gone"
                    tools:visibility="visible" />
            </LinearLayout>

            <!-- ===== Details section ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_m"
                android:background="@drawable/bg_back"
                android:orientation="vertical"
                android:padding="@dimen/space_m">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_semi"
                    android:text="@string/card_section_details"
                    android:textColor="@color/home_title"
                    android:textSize="14sp" />

                <!-- Holder -->
                <LinearLayout
                    android:id="@+id/tilHolder"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="@dimen/space_m"
                    android:background="@drawable/bg_lv_search"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="14dp">

                    <EditText
                        android:id="@+id/holderInput"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="@string/card_field_holder_name"
                        android:importantForAutofill="no"
                        android:inputType="textPersonName|textCapWords"
                        android:maxLines="1"
                        style="@style/TextAppearance.App.Medium"
                        android:textColor="@color/home_title"
                        android:textColorHint="@color/home_hint"
                        android:textSize="15sp" />
                </LinearLayout>

                <!-- Number -->
                <LinearLayout
                    android:id="@+id/tilNumber"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="@dimen/space_s"
                    android:background="@drawable/bg_lv_search"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="14dp">

                    <EditText
                        android:id="@+id/numberInput"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="@string/card_field_number"
                        android:importantForAutofill="no"
                        android:inputType="textCapCharacters"
                        android:maxLines="1"
                        style="@style/TextAppearance.App.Medium"
                        android:textColor="@color/home_title"
                        android:textColorHint="@color/home_hint"
                        android:textSize="15sp" />
                </LinearLayout>

                <!-- Secondary -->
                <LinearLayout
                    android:id="@+id/tilSecondary"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="@dimen/space_s"
                    android:background="@drawable/bg_lv_search"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="14dp"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <EditText
                        android:id="@+id/secondaryInput"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="@string/card_field_institute_name"
                        android:importantForAutofill="no"
                        android:inputType="textCapWords"
                        android:maxLines="1"
                        style="@style/TextAppearance.App.Medium"
                        android:textColor="@color/home_title"
                        android:textColorHint="@color/home_hint"
                        android:textSize="15sp" />
                </LinearLayout>

                <!-- Issuer -->
                <LinearLayout
                    android:id="@+id/tilIssuer"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="@dimen/space_s"
                    android:background="@drawable/bg_lv_search"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="14dp"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <EditText
                        android:id="@+id/issuerInput"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="@string/card_field_country"
                        android:importantForAutofill="no"
                        android:inputType="textCapWords"
                        android:maxLines="1"
                        style="@style/TextAppearance.App.Medium"
                        android:textColor="@color/home_title"
                        android:textColorHint="@color/home_hint"
                        android:textSize="15sp" />
                </LinearLayout>

                <!-- Expiry -->
                <LinearLayout
                    android:id="@+id/tilExpiry"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="@dimen/space_s"
                    android:background="@drawable/bg_lv_search"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="14dp">

                    <EditText
                        android:id="@+id/expiryInput"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@null"
                        android:clickable="true"
                        android:cursorVisible="false"
                        android:focusable="false"
                        android:hint="@string/card_field_expiry"
                        android:importantForAutofill="no"
                        android:inputType="none"
                        android:maxLines="1"
                        style="@style/TextAppearance.App.Medium"
                        android:textColor="@color/home_title"
                        android:textColorHint="@color/home_hint"
                        android:textSize="15sp" />

                    <ImageView
                        android:id="@+id/expiryClear"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/cd_card_icon"
                        android:padding="9dp"
                        android:src="@drawable/ic_close"
                        app:tint="@color/home_hint" />
                </LinearLayout>

                <!-- Notes -->
                <LinearLayout
                    android:id="@+id/tilNotes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_s"
                    android:background="@drawable/bg_lv_search"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="12dp">

                    <EditText
                        android:id="@+id/notesInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:gravity="top"
                        android:hint="@string/card_field_notes"
                        android:importantForAutofill="no"
                        android:inputType="textMultiLine|textCapSentences"
                        android:maxLines="4"
                        android:minLines="2"
                        style="@style/TextAppearance.App.Medium"
                        android:textColor="@color/home_title"
                        android:textColorHint="@color/home_hint"
                        android:textSize="15sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ===== Color section ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_m"
                android:background="@drawable/bg_back"
                android:orientation="vertical"
                android:padding="@dimen/space_m">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_semi"
                    android:text="@string/card_section_color"
                    android:textColor="@color/home_title"
                    android:textSize="14sp" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_m"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/colorSwatchRow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" />
                </HorizontalScrollView>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/saveButton"
                style="@style/Widget.App.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_l"
                app:backgroundTint="@color/home_primary"
                android:text="@string/card_save" />

            <ProgressBar
                android:id="@+id/saveProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/space_m"
                android:indeterminate="true"
                android:indeterminateTint="@color/home_primary"
                android:visibility="gone"
                tools:visibility="visible" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
