<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/overlayRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- ===== Standard / themed unlock panel ===== -->
    <LinearLayout
        android:id="@+id/standardPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_padding"
        android:paddingTop="@dimen/space_xxl"
        android:paddingEnd="@dimen/screen_padding"
        android:paddingBottom="@dimen/screen_padding">

        <FrameLayout
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginTop="@dimen/space_l"
            android:background="@drawable/bg_logo_circle"
            android:backgroundTint="@color/primary_container">

            <ImageView
                android:id="@+id/appIcon"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:contentDescription="@string/applock_overlay_title"
                android:src="@drawable/ic_lock"
                app:tint="@color/primary" />
        </FrameLayout>

        <TextView
            android:id="@+id/titlePin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_l"
            android:text="@string/applock_overlay_title"
            android:textAppearance="@style/TextAppearance.App.Title" />

        <TextView
            android:id="@+id/subtitlePin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_s"
            android:gravity="center"
            android:textAppearance="@style/TextAppearance.App.Body"
            tools:text="Instagram" />

        <LinearLayout
            android:id="@+id/pinDotsContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xl"
            android:gravity="center"
            android:orientation="horizontal" />

        <TextView
            android:id="@+id/errorPin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_m"
            android:gravity="center"
            android:textColor="@color/accent_red"
            android:textSize="@dimen/text_caption"
            android:visibility="invisible"
            tools:text="Wrong PIN" />

        <TextView
            android:id="@+id/tvLockoutTimer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:gravity="center"
            android:textColor="@color/accent_amber"
            android:textSize="@dimen/text_caption"
            android:textStyle="bold"
            android:visibility="gone"
            tools:text="Try again in 00:30" />

        <app.lock.photo.valut.core.ui.PatternLockView
            android:id="@+id/patternView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/space_m"
            android:layout_weight="1"
            android:contentDescription="@string/cd_pattern"
            android:visibility="gone" />

        <Space
            android:id="@+id/pinSpacer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <LinearLayout
            android:id="@+id/keypadContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <include layout="@layout/view_pin_keypad" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUseBiometric"
            style="@style/Widget.App.Button.Text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_s"
            android:text="@string/biometric_use"
            android:visibility="gone"
            app:icon="@drawable/ic_fingerprint" />
    </LinearLayout>

    <!-- ===== Fake crash panel ===== -->
    <LinearLayout
        android:id="@+id/crashPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/fake_crash_bg"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding"
        android:visibility="gone"
        tools:visibility="gone">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="@dimen/radius_s">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_l">

                <TextView
                    android:id="@+id/crashTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/fake_crash_title"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_heading"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/crashMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_s"
                    android:text="@string/fake_crash_message"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_body" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_l"
                    android:gravity="end"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/crashReport"
                        style="@style/Widget.App.Button.Text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/fake_crash_report" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/crashOpenAgain"
                        style="@style/Widget.App.Button.Text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/fake_crash_open_again" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/crashClose"
                        style="@style/Widget.App.Button.Text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/fake_crash_close" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- ===== Fake loading panel ===== -->
    <LinearLayout
        android:id="@+id/loadingPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding"
        android:visibility="gone"
        tools:visibility="gone">

        <ImageView
            android:id="@+id/loadingIcon"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:contentDescription="@string/fake_loading_text"
            android:src="@drawable/ic_lock"
            app:tint="@color/primary" />

        <ProgressBar
            android:id="@+id/loadingSpinner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_l" />

        <TextView
            android:id="@+id/loadingText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_l"
            android:text="@string/fake_loading_text"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_body" />
    </LinearLayout>

    <!-- ===== Fake calculator panel ===== -->
    <include
        android:id="@+id/calculatorPanel"
        layout="@layout/view_calculator_lock" />

</FrameLayout>
