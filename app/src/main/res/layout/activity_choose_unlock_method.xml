<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_xl"
        style="@style/TextAppearance.App.Bold"
        android:layout_marginHorizontal="@dimen/_8sdp"
        android:text="@string/choose_method_title"
        android:textAppearance="@style/TextAppearance.App.Title" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/TextAppearance.App.Medium"
        android:layout_marginTop="@dimen/space_m"
        android:layout_marginHorizontal="@dimen/_8sdp"
        android:lineSpacingExtra="4dp"
        android:text="@string/choose_method_subtitle"
        android:textAppearance="@style/TextAppearance.App.Body" />

    <!-- Pattern option (default) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardPattern"
        style="@style/Widget.App.Card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/_8sdp"
        android:layout_marginTop="@dimen/space_l"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/space_m">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:contentDescription="@string/cd_card_icon"
                android:src="@drawable/ic_shield"
                app:tint="@color/primary" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_m"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/choose_method_pattern_title"
                        android:textColor="@color/text_primary"
                        style="@style/TextAppearance.App.Bold"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_s"
                        android:background="@drawable/bg_note_encrypted_pill"
                        android:paddingStart="@dimen/space_s"
                        android:paddingTop="2dp"
                        android:paddingEnd="@dimen/space_s"
                        android:paddingBottom="2dp"
                        android:text="@string/choose_method_recommended"
                        android:textColor="@color/primary"
                        android:textSize="@dimen/text_caption" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    style="@style/TextAppearance.App.Medium"
                    android:text="@string/choose_method_pattern_desc"
                    android:textAppearance="@style/TextAppearance.App.Body" />
            </LinearLayout>

            <ImageView
                android:id="@+id/checkPattern"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="@dimen/space_s"
                android:contentDescription="@string/applock_perm_granted"
                android:src="@drawable/ic_check_circle"
                app:tint="@color/primary" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- PIN option -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardPin"
        style="@style/Widget.App.Card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/_8sdp"
        android:layout_marginTop="@dimen/space_m"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/space_m">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:contentDescription="@string/cd_card_icon"
                android:src="@drawable/ic_lock"
                app:tint="@color/primary" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_m"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/choose_method_pin_title"
                    style="@style/TextAppearance.App.Bold"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    style="@style/TextAppearance.App.Medium"
                    android:text="@string/choose_method_pin_desc"
                    android:textAppearance="@style/TextAppearance.App.Body" />
            </LinearLayout>

            <ImageView
                android:id="@+id/checkPin"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="@dimen/space_s"
                android:contentDescription="@string/applock_perm_granted"
                android:src="@drawable/ic_check_circle"
                android:visibility="invisible"
                app:tint="@color/primary" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnContinue"
        style="@style/Widget.App.Button.Primary"
        android:layout_marginHorizontal="@dimen/_16sdp"
        android:layout_marginBottom="@dimen/_16sdp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/continue_label" />

</LinearLayout>
