<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_bg"
    android:clipToPadding="false"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="20dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp">

        <!-- ===== Header ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/lv_brand_a"
                        android:textColor="@color/home_title"
                        android:textSize="30sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/lv_brand_b"
                        android:textColor="@color/home_primary"
                        android:textSize="30sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/lv_subtitle"
                    style="@style/TextAppearance.App.Medium"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/btnSettings"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/bg_lv_circle_light"
                android:clickable="true"
                android:contentDescription="@string/nav_settings"
                android:focusable="true">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_settings"
                    app:tint="@color/home_primary" />
            </FrameLayout>
        </LinearLayout>

        <!-- ===== Search ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_lv_search"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="14dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_search"
                app:tint="@color/home_hint" />

            <EditText
                android:id="@+id/searchInput"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:background="@null"
                android:hint="@string/lv_search_hint"
                android:importantForAutofill="no"
                android:layout_gravity="center"
                style="@style/TextAppearance.App.Medium"
                android:inputType="text"
                android:maxLines="1"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/home_hint"
                android:textSize="15sp" />

            <ImageView
                android:id="@+id/btnFilter"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@null"
                android:padding="7dp"
                android:src="@drawable/ic_filter"
                app:tint="@color/home_subtitle" />
        </LinearLayout>

        <!-- ===== Filter chips ===== -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:clipToPadding="false"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/chipAll"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_lv_chip_selected"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp">

                    <TextView
                        android:id="@+id/chipAllText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/lv_chip_all"
                        android:textColor="@color/white"
                        style="@style/TextAppearance.App.Medium"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/chipLocked"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_lv_chip_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="18dp">

                    <ImageView
                        android:id="@+id/chipLockedIcon"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginEnd="6dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_lock"
                        app:tint="@color/home_primary" />

                    <TextView
                        android:id="@+id/chipLockedText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/TextAppearance.App.Medium"

                        android:text="@string/lv_chip_locked"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/chipUnlocked"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_lv_chip_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="18dp">

                    <ImageView
                        android:id="@+id/chipUnlockedIcon"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginEnd="6dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_unlock"
                        app:tint="@color/home_success" />

                    <TextView
                        android:id="@+id/chipUnlockedText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/TextAppearance.App.Medium"

                        android:text="@string/lv_chip_unlocked"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/chipSystem"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_lv_chip_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="18dp">

                    <ImageView
                        android:id="@+id/chipSystemIcon"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginEnd="6dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_settings"
                        app:tint="@color/home_system_icon" />

                    <TextView
                        android:id="@+id/chipSystemText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/TextAppearance.App.Medium"

                        android:text="@string/lv_chip_system"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>
        </HorizontalScrollView>

        <!-- ===== Stats card ===== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardBackgroundColor="@color/home_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/home_border"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <LinearLayout style="@style/LvStatColumn">

                    <FrameLayout
                        style="@style/LvStatTile"
                        android:backgroundTint="@color/home_tile_purple">

                        <ImageView
                            style="@style/LvStatIcon"
                            android:src="@drawable/ic_lock"
                            app:tint="@color/home_primary" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvStatLocked"
                        style="@style/LvStatValue"
                        android:text="28" />

                    <TextView
                        style="@style/LvStatLabel"
                        android:text="@string/lv_stat_locked_apps" />
                </LinearLayout>

                <View style="@style/LvStatDivider" />

                <LinearLayout style="@style/LvStatColumn">

                    <FrameLayout
                        style="@style/LvStatTile"
                        android:backgroundTint="@color/home_tile_green">

                        <ImageView
                            style="@style/LvStatIcon"
                            android:src="@drawable/ic_shield"
                            app:tint="@color/home_success" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvStatProtection"
                        style="@style/LvStatValue"
                        android:text="@string/lv_stat_protection_value" />

                    <TextView
                        style="@style/LvStatLabel"
                        android:text="@string/lv_stat_protection" />
                </LinearLayout>

                <View style="@style/LvStatDivider" />

                <LinearLayout style="@style/LvStatColumn">

                    <FrameLayout
                        style="@style/LvStatTile"
                        android:backgroundTint="@color/home_tile_blue">

                        <ImageView
                            style="@style/LvStatIcon"
                            android:src="@drawable/ic_shield"
                            app:tint="@color/home_info" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvStatBlocked"
                        style="@style/LvStatValue"
                        android:text="0" />

                    <TextView
                        style="@style/LvStatLabel"
                        android:text="@string/lv_stat_blocked" />
                </LinearLayout>

                <View style="@style/LvStatDivider" />

                <LinearLayout style="@style/LvStatColumn">

                    <FrameLayout
                        style="@style/LvStatTile"
                        android:backgroundTint="@color/home_tile_teal">

                        <ImageView
                            style="@style/LvStatIcon"
                            android:src="@drawable/ic_clock"
                            app:tint="@color/home_teal" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvStatTime"
                        style="@style/LvStatValue"
                        android:text="0m" />

                    <TextView
                        style="@style/LvStatLabel"
                        android:singleLine="true"
                        android:text="@string/lv_stat_time" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== Installed Apps header ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/lv_installed_apps"
                android:textColor="@color/text_primary"
                android:textSize="17sp"
                style="@style/TextAppearance.App.Body"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAppCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textColor="@color/text_secondary"
                style="@style/TextAppearance.App.Medium"
                android:textSize="12sp"
                tools:text="(120)" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <LinearLayout
                android:id="@+id/btnSort"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="4dp">

                <TextView
                    android:id="@+id/tvSortLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/lv_sort_az"
                    android:textColor="@color/text_secondary"
                    style="@style/TextAppearance.App.Regular"
                    android:textSize="14sp" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="2dp"
                    android:contentDescription="@null"
                    android:rotation="90"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="@color/text_secondary" />
            </LinearLayout>
        </LinearLayout>

        <!-- ===== Installed apps list ===== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/home_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/home_border"
            app:strokeWidth="0dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="120dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    tools:itemCount="4"
                    tools:listitem="@layout/item_installed_app" />

                <ProgressBar
                    android:id="@+id/progress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_margin="24dp" />

                <TextView
                    android:id="@+id/emptyText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_margin="24dp"
                    android:text="@string/applock_no_apps"
                    android:textColor="@color/home_subtitle"
                    android:textSize="14sp"
                    android:visibility="gone" />
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== Complete Setup card ===== -->
        <LinearLayout
            android:id="@+id/setupCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_lv_setup_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="14dp">

            <FrameLayout
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/bg_lv_icon_tile"
                android:backgroundTint="@color/home_primary_light">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_shield"
                    app:tint="@color/home_primary" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/lv_complete_setup"
                    android:textColor="@color/home_primary"
                    android:fontFamily="@font/inter_semi"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    style="@style/TextAppearance.App.Medium"
                    android:text="@string/lv_complete_setup_sub"
                    android:textColor="@color/home_subtitle"
                    android:textSize="12.5sp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFinishSetup"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="@string/lv_finish_setup"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="13sp"
                app:backgroundTint="@color/home_primary"
                app:cornerRadius="12dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
