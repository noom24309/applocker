<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- ===== Custom Bottom Navigation (no BottomNavigationView) ===== -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_lv_bottom_nav"
        android:elevation="14dp"
        android:paddingBottom="8dp"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/navHome"
            style="@style/LvNavTab">

            <View
                android:id="@+id/navHomeIndicator"
                style="@style/LvNavIndicator"
                android:backgroundTint="@color/home_primary" />

            <ImageView
                android:id="@+id/navHomeIcon"
                style="@style/LvNavIcon"
                android:src="@drawable/home_ic"
                app:tint="@color/home_primary" />

            <TextView
                android:id="@+id/navHomeLabel"
                style="@style/LvNavLabel"
                android:text="@string/lv_nav_home"
                android:textColor="@color/home_primary"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navVault"
            style="@style/LvNavTab">

            <View
                android:id="@+id/navVaultIndicator"
                style="@style/LvNavIndicator"
                android:backgroundTint="@color/home_primary"
                android:visibility="invisible" />

            <ImageView
                android:id="@+id/navVaultIcon"
                style="@style/LvNavIcon"
                android:src="@drawable/valute_ic"
                app:tint="@color/home_system_icon" />

            <TextView
                android:id="@+id/navVaultLabel"
                style="@style/LvNavLabel"
                android:text="@string/lv_nav_vault"
                android:textColor="@color/home_system_icon" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navTools"
            style="@style/LvNavTab">

            <View
                android:id="@+id/navToolsIndicator"
                style="@style/LvNavIndicator"
                android:backgroundTint="@color/home_primary"
                android:visibility="invisible" />

            <ImageView
                android:id="@+id/navToolsIcon"
                style="@style/LvNavIcon"
                android:src="@drawable/more_ic"
                app:tint="@color/home_system_icon" />

            <TextView
                android:id="@+id/navToolsLabel"
                style="@style/LvNavLabel"
                android:text="@string/lv_nav_tools"
                android:textColor="@color/home_system_icon" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/fr_ads"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent">

        <include layout="@layout/layout_banner_control"/>
    </FrameLayout>

</LinearLayout>
