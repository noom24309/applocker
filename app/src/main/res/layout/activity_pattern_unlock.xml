<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="@dimen/screen_padding"
    android:paddingTop="@dimen/space_xxl"
    android:paddingEnd="@dimen/screen_padding"
    android:paddingBottom="@dimen/screen_padding">

    <FrameLayout
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginTop="@dimen/space_l"
        android:background="@drawable/bg_logo_circle"
        android:backgroundTint="@color/primary_container">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:contentDescription="@string/cd_app_logo"
            android:src="@drawable/ic_lock"
            app:tint="@color/primary" />
    </FrameLayout>

    <TextView
        android:id="@+id/titlePattern"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        style="@style/TextAppearance.App.Bold"
        android:layout_marginTop="@dimen/space_l"
        android:text="@string/pattern_unlock_title"
        android:textAppearance="@style/TextAppearance.App.Title" />

    <TextView
        android:id="@+id/errorPattern"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_s"
        android:gravity="center"
        android:textColor="@color/accent_red"
        android:textSize="@dimen/text_caption"
        android:visibility="invisible"
        tools:text="Wrong pattern" />

    <TextView
        android:id="@+id/tvLockoutTimer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_xs"
        android:gravity="center"
        android:textColor="@color/accent_amber"
        android:textSize="@dimen/text_caption"
        android:textStyle="bold"
        android:visibility="gone"
        tools:text="Try again in 00:30"
        tools:visibility="visible" />

    <app.lock.photo.valut.core.ui.PatternLockView
        android:id="@+id/patternView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/space_m"
        android:layout_weight="1"
        android:contentDescription="@string/cd_pattern" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnUseBiometric"
        style="@style/Widget.App.Button.Text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:icon="@drawable/ic_fingerprint"
        android:text="@string/biometric_use"
        android:visibility="gone"
        tools:visibility="visible" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnForgotPin"
        style="@style/Widget.App.Button.Text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/forgot_pin" />

</LinearLayout>
