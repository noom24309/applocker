<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:title="@string/duplicates_title"
        app:titleTextColor="@color/text_primary" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnScan"
        style="@style/Widget.App.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_m"
        android:layout_marginEnd="@dimen/space_m"
        android:text="@string/duplicates_scan" />

    <ProgressBar
        android:id="@+id/scanProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_m"
        android:layout_marginEnd="@dimen/space_m"
        android:layout_marginTop="@dimen/space_s"
        android:visibility="gone"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/scanStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_m"
        android:layout_marginTop="4dp"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_caption"
        android:visibility="gone"
        tools:text="Scanning… 12/240"
        tools:visibility="visible" />

    <HorizontalScrollView
        android:id="@+id/quickSelectRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_s"
        android:paddingStart="@dimen/space_m"
        android:paddingEnd="@dimen/space_m"
        android:scrollbars="none"
        android:visibility="gone"
        tools:visibility="visible">

        <com.google.android.material.chip.ChipGroup
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleLine="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipKeepBest"
                style="@style/Widget.App.Chip.SoftClose"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/duplicates_keep_best" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipKeepNewest"
                style="@style/Widget.App.Chip.SoftClose"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/duplicates_keep_newest" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipKeepOldest"
                style="@style/Widget.App.Chip.SoftClose"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/duplicates_keep_oldest" />
        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="@dimen/space_s">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="@dimen/space_s"
            tools:listitem="@layout/item_cleanup_media" />

        <TextView
            android:id="@+id/emptyView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:padding="@dimen/space_l"
            android:text="@string/duplicates_not_scanned"
            android:textColor="@color/text_tertiary"
            android:textSize="@dimen/text_body"
            tools:visibility="visible" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/space_m"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:id="@+id/selectionSummary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_body"
            tools:text="6 selected · 192 MB" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDelete"
            style="@style/Widget.App.Button.Primary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cleanup_delete_selected" />
    </LinearLayout>
</LinearLayout>
