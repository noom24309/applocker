<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_bg"
    android:orientation="vertical">

    <!-- ===== Toolbar ===== -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="8dp">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="6dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_card_icon"
            android:padding="9dp"
            android:src="@drawable/ic_arrow_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/home_title" />

        <TextView
            android:id="@+id/title"
            style="@style/TextAppearance.App.Bold"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:gravity="center_vertical"
            android:text="@string/card_detail_title"
            android:textColor="@color/home_title"
            android:textSize="22sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/toolbarActions"
            app:layout_constraintStart_toEndOf="@+id/iv_back"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/toolbarActions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/action_favorite"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/action_favorite"
                android:padding="8dp"
                android:src="@drawable/ic_favorite_border"
                app:tint="@color/home_title" />

            <ImageView
                android:id="@+id/action_edit"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/card_action_edit"
                android:padding="8dp"
                android:src="@drawable/ic_edit"
                app:tint="@color/home_title" />

            <ImageView
                android:id="@+id/action_export"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/card_action_export"
                android:padding="8dp"
                android:src="@drawable/ic_export"
                app:tint="@color/home_title" />

            <ImageView
                android:id="@+id/action_delete"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/delete_label"
                android:padding="8dp"
                android:src="@drawable/ic_delete"
                app:tint="@color/accent_red" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_padding"
            android:paddingTop="@dimen/space_s"
            android:paddingEnd="@dimen/screen_padding"
            android:paddingBottom="@dimen/space_xl">

            <!-- Wallet preview -->
            <include
                android:id="@+id/preview"
                layout="@layout/item_document_card" />

            <!-- ===== Image cards ===== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/frontImageCard"
                android:layout_width="match_parent"
                android:layout_height="@dimen/card_image_height"
                android:layout_marginTop="@dimen/space_l"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone"
                app:cardBackgroundColor="@color/home_tile_blue"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/home_border"
                app:strokeWidth="1dp"
                tools:visibility="visible">

                <ImageView
                    android:id="@+id/frontImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/cd_card_front"
                    android:scaleType="centerCrop" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/backImageCard"
                android:layout_width="match_parent"
                android:layout_height="@dimen/card_image_height"
                android:layout_marginTop="@dimen/space_s"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone"
                app:cardBackgroundColor="@color/home_tile_blue"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/home_border"
                app:strokeWidth="1dp"
                tools:visibility="visible">

                <ImageView
                    android:id="@+id/backImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/cd_card_back"
                    android:scaleType="centerCrop" />
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== Details card ===== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_l"
                app:cardBackgroundColor="@color/home_card"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/home_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_l">

                    <!-- Card header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_lv_icon_tile"
                            android:backgroundTint="@color/home_tile_purple">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_card_id"
                                app:tint="@color/home_primary" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/inter_semi"
                            android:text="@string/card_section_details"
                            android:textColor="@color/home_title"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="@dimen/space_l"
                        android:background="@color/home_divider" />

                    <!-- Holder -->
                    <LinearLayout
                        android:id="@+id/rowHolder"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_l"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/holderLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter_medium"
                            android:textColor="@color/home_subtitle"
                            android:textSize="@dimen/text_caption"
                            tools:text="Holder name" />

                        <TextView
                            android:id="@+id/holderValue"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:fontFamily="@font/inter_semi"
                            android:textColor="@color/home_title"
                            android:textSize="16sp"
                            tools:text="Ahmed Ali" />
                    </LinearLayout>

                    <!-- Number with show/hide -->
                    <LinearLayout
                        android:id="@+id/rowNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_l"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/numberLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter_medium"
                                android:textColor="@color/home_subtitle"
                                android:textSize="@dimen/text_caption"
                                tools:text="ID number" />

                            <TextView
                                android:id="@+id/numberValue"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:fontFamily="@font/inter_semi"
                                android:fontFeatureSettings="tnum"
                                android:letterSpacing="0.08"
                                android:textColor="@color/home_title"
                                android:textSize="16sp"
                                tools:text="•••• 4321" />
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/showHideButton"
                            style="@style/Widget.Material3.Button.TextButton.Icon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/card_show_number"
                            android:textColor="@color/home_primary"
                            app:icon="@drawable/ic_visibility"
                            app:iconTint="@color/home_primary" />
                    </LinearLayout>

                    <!-- Secondary -->
                    <LinearLayout
                        android:id="@+id/rowSecondary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_l"
                        android:orientation="vertical"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <TextView
                            android:id="@+id/secondaryLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter_medium"
                            android:textColor="@color/home_subtitle"
                            android:textSize="@dimen/text_caption"
                            tools:text="Institute name" />

                        <TextView
                            android:id="@+id/secondaryValue"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:fontFamily="@font/inter_semi"
                            android:textColor="@color/home_title"
                            android:textSize="16sp"
                            tools:text="City University" />
                    </LinearLayout>

                    <!-- Issuer -->
                    <LinearLayout
                        android:id="@+id/rowIssuer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_l"
                        android:orientation="vertical"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <TextView
                            android:id="@+id/issuerLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter_medium"
                            android:textColor="@color/home_subtitle"
                            android:textSize="@dimen/text_caption"
                            tools:text="Country" />

                        <TextView
                            android:id="@+id/issuerValue"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:fontFamily="@font/inter_semi"
                            android:textColor="@color/home_title"
                            android:textSize="16sp"
                            tools:text="United Kingdom" />
                    </LinearLayout>

                    <!-- Expiry -->
                    <LinearLayout
                        android:id="@+id/rowExpiry"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_l"
                        android:orientation="vertical"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter_medium"
                            android:text="@string/card_field_expiry"
                            android:textColor="@color/home_subtitle"
                            android:textSize="@dimen/text_caption" />

                        <TextView
                            android:id="@+id/expiryValue"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:fontFamily="@font/inter_semi"
                            android:textColor="@color/home_title"
                            android:textSize="16sp"
                            tools:text="12/2029" />
                    </LinearLayout>

                    <!-- Notes -->
                    <LinearLayout
                        android:id="@+id/rowNotes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_l"
                        android:orientation="vertical"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter_medium"
                            android:text="@string/card_field_notes"
                            android:textColor="@color/home_subtitle"
                            android:textSize="@dimen/text_caption" />

                        <TextView
                            android:id="@+id/notesValue"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:fontFamily="@font/inter_medium"
                            android:lineSpacingMultiplier="1.3"
                            android:textColor="@color/home_title"
                            android:textSize="15sp"
                            tools:text="Some notes" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== Meta footer ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_l"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/space_xs"
                android:paddingEnd="@dimen/space_xs">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_info"
                    app:tint="@color/home_hint" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/createdText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_medium"
                        android:textColor="@color/home_hint"
                        android:textSize="@dimen/text_caption"
                        tools:text="Added 12 Jun 2026" />

                    <TextView
                        android:id="@+id/updatedText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/inter_medium"
                        android:textColor="@color/home_hint"
                        android:textSize="@dimen/text_caption"
                        tools:text="Updated 12 Jun 2026" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
