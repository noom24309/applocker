<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surface"
    android:maxHeight="520dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_padding"
        android:paddingTop="@dimen/space_m"
        android:paddingEnd="@dimen/screen_padding"
        android:paddingBottom="@dimen/space_l">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="@dimen/space_s"
            android:text="@string/camera_settings_title"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_heading"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/rowDefaultFacing"
            style="@style/CameraSettingChoiceRow"
            tools:text="Default camera: Back" />

        <TextView
            android:id="@+id/rowDefaultMode"
            style="@style/CameraSettingChoiceRow"
            tools:text="Default mode: Photo" />

        <TextView
            android:id="@+id/rowVideoQuality"
            style="@style/CameraSettingChoiceRow"
            tools:text="Video quality: Standard" />

        <TextView
            android:id="@+id/rowPhotoQuality"
            style="@style/CameraSettingChoiceRow"
            tools:text="Photo quality: Standard" />

        <LinearLayout style="@style/CameraSettingSwitchRow">

            <TextView
                style="@style/CameraSettingSwitchLabel"
                android:text="@string/camera_setting_record_audio" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchAudio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout style="@style/CameraSettingSwitchRow">

            <TextView
                style="@style/CameraSettingSwitchLabel"
                android:text="@string/camera_setting_keep_awake" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchKeepAwake"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout style="@style/CameraSettingSwitchRow">

            <TextView
                style="@style/CameraSettingSwitchLabel"
                android:text="@string/camera_setting_show_preview" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchShowPreview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
