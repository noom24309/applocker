<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_bg"
    android:orientation="vertical">

    <!-- ===== Toolbar ===== -->
    <ImageView
        android:id="@+id/ivBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="14dp"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/cd_card_icon"
        android:padding="9dp"
        android:rotation="180"
        android:src="@drawable/ic_chevron_right"
        app:tint="@color/home_title" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="8dp"
        android:paddingEnd="24dp"
        android:paddingBottom="20dp">

        <FrameLayout
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:background="@drawable/bg_tile_purple">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_lock"
                app:tint="@color/home_primary" />
        </FrameLayout>

        <TextView
            android:id="@+id/titlePattern"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            style="@style/TextAppearance.App.Bold"
            android:gravity="center"
            android:text="@string/pattern_setup_title"
            android:textColor="@color/home_title"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/subtitlePattern"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            style="@style/TextAppearance.App.Medium"
            android:gravity="center"
            android:text="@string/pattern_setup_subtitle"
            android:textColor="@color/home_subtitle"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/errorPattern"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_m"
            android:gravity="center"
            android:textColor="@color/accent_red"
            android:textSize="@dimen/text_caption"
            android:visibility="invisible"
            tools:text="Patterns don't match" />

        <app.lock.photo.valut.core.ui.PatternLockView
            android:id="@+id/patternView"
            android:layout_width="match_parent"
            android:background="@drawable/bg_back"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/space_l"
            android:layout_weight="1"
            android:contentDescription="@string/cd_pattern" />

        <!-- ===== Hint note ===== -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_l"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="7dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_shield"
                app:tint="@color/home_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TextAppearance.App.Regular"
                android:text="@string/pattern_hint_note"
                android:textColor="@color/home_subtitle"
                android:textSize="12.5sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/btnContinue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_button_primary"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center"
            android:minHeight="@dimen/button_height"
            android:layout_marginTop="@dimen/_4sdp"
            style="@style/TextAppearance.App.SemiBold"
            android:paddingVertical="12dp"
            android:textAllCaps="false"
            android:textColor="@color/text_on_primary"
            android:letterSpacing="0.01"
            android:textSize="16sp"
            android:text="@string/continue_label" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClear"
            style="@style/Widget.App.Button.Text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/pattern_clear"
            android:textColor="@color/home_primary" />

    </LinearLayout>

</LinearLayout>
