<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:gravity="center_horizontal"
    android:orientation="vertical">

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <FrameLayout
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:background="@drawable/bg_logo_circle"
        android:backgroundTint="@color/primary_container">

        <ImageView
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_gravity="center"
            android:contentDescription="@string/cd_biometric"
            android:src="@drawable/ic_fingerprint"
            app:tint="@color/primary" />
    </FrameLayout>

    <TextView
        android:id="@+id/title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/TextAppearance.App.Bold"
        android:layout_marginTop="@dimen/space_xl"
        android:gravity="center"
        android:text="@string/biometric_title"/>

    <TextView
        android:id="@+id/subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_m"
        android:gravity="center"
        style="@style/TextAppearance.App.Medium"
        android:lineSpacingExtra="4dp"
        android:text="@string/biometric_subtitle" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <TextView
        android:id="@+id/btnPrimary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_button_primary"
        android:foreground="?attr/selectableItemBackground"
        android:gravity="center"
        android:minHeight="@dimen/button_height"
        android:layout_marginHorizontal="@dimen/_16sdp"
        style="@style/TextAppearance.App.SemiBold"
        android:paddingVertical="12dp"
        android:text="@string/biometric_enable"
        android:textAllCaps="false"
        android:textColor="@color/text_on_primary"
        android:letterSpacing="0.01"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/btnSkip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_s"
        android:foreground="?attr/selectableItemBackground"
        android:gravity="center"
        style="@style/TextAppearance.App.Medium"
        android:paddingVertical="10dp"
        android:text="@string/skip"
        android:textAllCaps="false"
        android:textColor="@color/text_secondary"
        android:textSize="15sp" />

</LinearLayout>
