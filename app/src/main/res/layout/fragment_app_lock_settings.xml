<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:title="@string/applock_settings_title"
        app:titleTextColor="@color/text_primary" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_padding"
            android:paddingTop="@dimen/space_s"
            android:paddingEnd="@dimen/screen_padding"
            android:paddingBottom="@dimen/space_l">

            <!-- A. Protection -->
            <TextView
                style="@style/SettingsSectionHeader"
                android:text="@string/applock_section_protection" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.App.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/rowMaster"
                        style="@style/SettingsRow">

                        <ImageView
                            style="@style/SettingsRowIcon"
                            android:src="@drawable/ic_shield"
                            app:tint="@color/primary" />

                        <LinearLayout style="@style/SettingsRowText">

                            <TextView
                                style="@style/SettingsRowTitle"
                                android:text="@string/applock_setting_master" />

                            <TextView
                                style="@style/SettingsRowDesc"
                                android:text="@string/applock_setting_master_desc" />
                        </LinearLayout>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switchMaster"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>

                    <View style="@style/SettingsDivider" />

                    <LinearLayout
                        android:id="@+id/rowLockNew"
                        style="@style/SettingsRow">

                        <ImageView
                            style="@style/SettingsRowIcon"
                            android:src="@drawable/ic_add"
                            app:tint="@color/primary" />

                        <LinearLayout style="@style/SettingsRowText">

                            <TextView
                                style="@style/SettingsRowTitle"
                                android:text="@string/applock_setting_lock_new" />

                            <TextView
                                style="@style/SettingsRowDesc"
                                android:text="@string/applock_setting_lock_new_desc" />
                        </LinearLayout>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switchLockNew"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- B. Unlock -->
            <TextView
                style="@style/SettingsSectionHeader"
                android:text="@string/applock_section_unlock" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.App.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        style="@style/SettingsRow"
                        android:clickable="false">

                        <ImageView
                            style="@style/SettingsRowIcon"
                            android:src="@drawable/ic_fingerprint"
                            app:tint="@color/primary" />

                        <LinearLayout style="@style/SettingsRowText">

                            <TextView
                                style="@style/SettingsRowTitle"
                                android:text="@string/applock_setting_unlock_method" />

                            <TextView
                                style="@style/SettingsRowDesc"
                                android:text="@string/applock_setting_unlock_method_desc" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvUnlockMethod"
                            style="@style/SettingsRowValue"
                            tools:text="PIN" />
                    </LinearLayout>

                    <View style="@style/SettingsDivider" />

                    <LinearLayout
                        android:id="@+id/rowDelay"
                        style="@style/SettingsRow">

                        <ImageView
                            style="@style/SettingsRowIcon"
                            android:src="@drawable/ic_lock"
                            app:tint="@color/primary" />

                        <LinearLayout style="@style/SettingsRowText">

                            <TextView
                                style="@style/SettingsRowTitle"
                                android:text="@string/applock_setting_delay" />

                            <TextView
                                style="@style/SettingsRowDesc"
                                android:text="@string/applock_setting_delay_desc" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvDelayValue"
                            style="@style/SettingsRowValue"
                            tools:text="Immediately" />

                        <ImageView
                            style="@style/SettingsRowTrailingIcon"
                            android:src="@drawable/ic_chevron_right" />
                    </LinearLayout>

                    <View style="@style/SettingsDivider" />

                    <LinearLayout
                        android:id="@+id/rowScreenOff"
                        style="@style/SettingsRow">

                        <ImageView
                            style="@style/SettingsRowIcon"
                            android:src="@drawable/ic_lock"
                            app:tint="@color/primary" />

                        <LinearLayout style="@style/SettingsRowText">

                            <TextView
                                style="@style/SettingsRowTitle"
                                android:text="@string/applock_setting_screen_off" />

                            <TextView
                                style="@style/SettingsRowDesc"
                                android:text="@string/applock_setting_screen_off_desc" />
                        </LinearLayout>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switchScreenOff"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>

                    <View style="@style/SettingsDivider" />

                    <LinearLayout
                        android:id="@+id/rowAppSwitch"
                        style="@style/SettingsRow">

                        <ImageView
                            style="@style/SettingsRowIcon"
                            android:src="@drawable/ic_lock"
                            app:tint="@color/primary" />

                        <LinearLayout style="@style/SettingsRowText">

                            <TextView
                                style="@style/SettingsRowTitle"
                                android:text="@string/applock_setting_app_switch" />

                            <TextView
                                style="@style/SettingsRowDesc"
                                android:text="@string/applock_setting_app_switch_desc" />
                        </LinearLayout>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switchAppSwitch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>

                    <View style="@style/SettingsDivider" />

                    <LinearLayout
                        android:id="@+id/rowDeviceLock"
                        style="@style/SettingsRow">

                        <ImageView
                            style="@style/SettingsRowIcon"
                            android:src="@drawable/ic_lock"
                            app:tint="@color/primary" />

                        <LinearLayout style="@style/SettingsRowText">

                            <TextView
                                style="@style/SettingsRowTitle"
                                android:text="@string/applock_setting_device_lock" />

                            <TextView
                                style="@style/SettingsRowDesc"
                                android:text="@string/applock_setting_device_lock_desc" />
                        </LinearLayout>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switchDeviceLock"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- C. Disguise -->
            <TextView
                style="@style/SettingsSectionHeader"
                android:text="@string/applock_section_disguise" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.App.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/rowTheme"
                        style="@style/SettingsRow">

                        <ImageView
                            style="@style/SettingsRowIcon"
                            android:src="@drawable/ic_shield"
                            app:tint="@color/primary" />

                        <LinearLayout style="@style/SettingsRowText">

                            <TextView
                                style="@style/SettingsRowTitle"
                                android:text="@string/applock_setting_theme" />

                            <TextView
                                style="@style/SettingsRowDesc"
                                android:text="@string/applock_setting_theme_desc" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvThemeValue"
                            style="@style/SettingsRowValue"
                            tools:text="Default" />

                        <ImageView
                            style="@style/SettingsRowTrailingIcon"
                            android:src="@drawable/ic_chevron_right" />
                    </LinearLayout>

                    <View style="@style/SettingsDivider" />

                    <LinearLayout
                        android:id="@+id/rowFakeMode"
                        style="@style/SettingsRow">

                        <ImageView
                            style="@style/SettingsRowIcon"
                            android:src="@drawable/ic_intruder"
                            app:tint="@color/primary" />

                        <LinearLayout style="@style/SettingsRowText">

                            <TextView
                                style="@style/SettingsRowTitle"
                                android:text="@string/applock_setting_fake_mode" />

                            <TextView
                                style="@style/SettingsRowDesc"
                                android:text="@string/applock_setting_fake_mode_desc" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvFakeValue"
                            style="@style/SettingsRowValue"
                            tools:text="Off" />

                        <ImageView
                            style="@style/SettingsRowTrailingIcon"
                            android:src="@drawable/ic_chevron_right" />
                    </LinearLayout>

                    <View style="@style/SettingsDivider" />

                    <LinearLayout
                        android:id="@+id/rowHideName"
                        style="@style/SettingsRow">

                        <ImageView
                            style="@style/SettingsRowIcon"
                            android:src="@drawable/ic_shield"
                            app:tint="@color/primary" />

                        <LinearLayout style="@style/SettingsRowText">

                            <TextView
                                style="@style/SettingsRowTitle"
                                android:text="@string/applock_setting_hide_name" />

                            <TextView
                                style="@style/SettingsRowDesc"
                                android:text="@string/applock_setting_hide_name_desc" />
                        </LinearLayout>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switchHideName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- D. Privacy -->
            <TextView
                style="@style/SettingsSectionHeader"
                android:text="@string/applock_section_privacy" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.App.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/rowHideRecent"
                        style="@style/SettingsRow">

                        <ImageView
                            style="@style/SettingsRowIcon"
                            android:src="@drawable/ic_shield"
                            app:tint="@color/primary" />

                        <LinearLayout style="@style/SettingsRowText">

                            <TextView
                                style="@style/SettingsRowTitle"
                                android:text="@string/applock_setting_hide_recent" />

                            <TextView
                                style="@style/SettingsRowDesc"
                                android:text="@string/applock_setting_hide_recent_desc" />
                        </LinearLayout>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switchHideRecent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>

                    <View style="@style/SettingsDivider" />

                    <LinearLayout
                        android:id="@+id/rowLocalStats"
                        style="@style/SettingsRow">

                        <ImageView
                            style="@style/SettingsRowIcon"
                            android:src="@drawable/ic_check_circle"
                            app:tint="@color/primary" />

                        <LinearLayout style="@style/SettingsRowText">

                            <TextView
                                style="@style/SettingsRowTitle"
                                android:text="@string/applock_setting_local_stats" />

                            <TextView
                                style="@style/SettingsRowDesc"
                                android:text="@string/applock_setting_local_stats_desc" />
                        </LinearLayout>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switchLocalStats"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>

                    <View style="@style/SettingsDivider" />

                    <LinearLayout
                        android:id="@+id/rowPermissions"
                        style="@style/SettingsRow">

                        <ImageView
                            style="@style/SettingsRowIcon"
                            android:src="@drawable/ic_shield"
                            app:tint="@color/primary" />

                        <LinearLayout style="@style/SettingsRowText">

                            <TextView
                                style="@style/SettingsRowTitle"
                                android:text="@string/applock_setting_permissions" />

                            <TextView
                                android:id="@+id/tvPermissionStatus"
                                style="@style/SettingsRowDesc"
                                tools:text="All granted" />
                        </LinearLayout>

                        <ImageView
                            style="@style/SettingsRowTrailingIcon"
                            android:src="@drawable/ic_chevron_right" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- E. Stability -->
            <TextView
                style="@style/SettingsSectionHeader"
                android:text="@string/applock_section_stability" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.App.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/rowBattery"
                        style="@style/SettingsRow">

                        <ImageView
                            style="@style/SettingsRowIcon"
                            android:src="@drawable/ic_shield"
                            app:tint="@color/primary" />

                        <LinearLayout style="@style/SettingsRowText">

                            <TextView
                                style="@style/SettingsRowTitle"
                                android:text="@string/applock_setting_battery" />

                            <TextView
                                style="@style/SettingsRowDesc"
                                android:text="@string/applock_setting_battery_desc" />
                        </LinearLayout>

                        <ImageView
                            style="@style/SettingsRowTrailingIcon"
                            android:src="@drawable/ic_chevron_right" />
                    </LinearLayout>

                    <View style="@style/SettingsDivider" />

                    <LinearLayout
                        android:id="@+id/rowRestartBoot"
                        style="@style/SettingsRow">

                        <ImageView
                            style="@style/SettingsRowIcon"
                            android:src="@drawable/ic_restore"
                            app:tint="@color/primary" />

                        <LinearLayout style="@style/SettingsRowText">

                            <TextView
                                style="@style/SettingsRowTitle"
                                android:text="@string/applock_setting_restart_boot" />

                            <TextView
                                style="@style/SettingsRowDesc"
                                android:text="@string/applock_setting_restart_boot_desc" />
                        </LinearLayout>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/switchRestartBoot"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>

                    <View style="@style/SettingsDivider" />

                    <LinearLayout
                        android:id="@+id/rowTroubleshoot"
                        style="@style/SettingsRow">

                        <ImageView
                            style="@style/SettingsRowIcon"
                            android:src="@drawable/ic_settings"
                            app:tint="@color/primary" />

                        <LinearLayout style="@style/SettingsRowText">

                            <TextView
                                style="@style/SettingsRowTitle"
                                android:text="@string/applock_setting_troubleshoot" />

                            <TextView
                                style="@style/SettingsRowDesc"
                                android:text="@string/applock_setting_troubleshoot_desc" />
                        </LinearLayout>

                        <ImageView
                            style="@style/SettingsRowTrailingIcon"
                            android:src="@drawable/ic_chevron_right" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
