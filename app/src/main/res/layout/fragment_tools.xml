<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_bg"
    android:clipToPadding="false"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="20dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp">

        <!-- ===== Header ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/lv_brand_a"
                        android:textColor="@color/home_title"
                        android:textSize="30sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/lv_brand_b"
                        android:textColor="@color/home_primary"
                        android:textSize="30sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    style="@style/TextAppearance.App.Medium"
                    android:text="@string/tools_header_subtitle"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/btnSettings"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/bg_lv_circle_light"
                android:clickable="true"
                android:contentDescription="@string/nav_settings"
                android:focusable="true">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_settings"
                    app:tint="@color/home_primary" />
            </FrameLayout>
        </LinearLayout>

        <!-- ===== Hero card ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_hero_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="18dp">

            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_hero_pill">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_shield"
                    app:tint="@color/white" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tools_hero_title"
                    android:textColor="@color/white"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    style="@style/TextAppearance.App.Medium"
                    android:text="@string/tools_hero_desc"
                    android:textColor="@color/hero_text_muted"
                    android:textSize="12.5sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="62dp"
                    android:layout_height="62dp"
                    android:background="@drawable/bg_hero_ring">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="@string/tools_hero_percent"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    style="@style/TextAppearance.App.Medium"
                    android:text="@string/tools_hero_protected"
                    android:textColor="@color/hero_text_muted"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ===== Cleanup Tools ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="@string/tools_section_cleanup"
            android:textColor="@color/home_title"
            android:textSize="17sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardDuplicates"
                style="@style/ToolTileCard"
                android:background="@drawable/bg_back"
                android:layout_marginEnd="6dp">

                <LinearLayout style="@style/ToolTileContent">

                    <FrameLayout
                        style="@style/ToolTileIconBox"
                        android:background="@drawable/bg_tile_purple">

                        <ImageView
                            style="@style/ToolTileIcon"
                            android:src="@drawable/ic_duplicate"
                            app:tint="@color/home_primary" />
                    </FrameLayout>

                    <TextView
                        style="@style/ToolTileTitle"
                        android:text="@string/tools_duplicate_finder" />

                    <TextView
                        style="@style/ToolTileDesc"
                        android:visibility="gone"
                        android:text="@string/tools_duplicate_desc" />

                    <TextView
                        android:id="@+id/tvDuplicatesValue"
                        style="@style/ToolTileValue"
                        android:visibility="gone"

                        android:text="@string/tools_sample_dup_size"
                        android:textColor="@color/home_primary" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardLargeFiles"
                style="@style/ToolTileCard"
                android:background="@drawable/bg_back"

                android:layout_marginStart="6dp">

                <LinearLayout style="@style/ToolTileContent">

                    <FrameLayout
                        style="@style/ToolTileIconBox"
                        android:background="@drawable/bg_tile_blue">

                        <ImageView
                            style="@style/ToolTileIcon"
                            android:src="@drawable/ic_folder"
                            app:tint="@color/accent_blue" />
                    </FrameLayout>

                    <TextView
                        style="@style/ToolTileTitle"
                        android:text="@string/tools_large_files" />

                    <TextView
                        style="@style/ToolTileDesc"
                        android:visibility="gone"

                        android:text="@string/tools_large_files_desc" />

                    <TextView
                        android:id="@+id/tvLargeFilesValue"
                        style="@style/ToolTileValue"
                        android:visibility="gone"

                        android:text="@string/tools_sample_large_size"
                        android:textColor="@color/accent_blue" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardStorage"
                android:background="@drawable/bg_back"

                style="@style/ToolTileCard">

                <LinearLayout style="@style/ToolTileContent">

                    <FrameLayout
                        style="@style/ToolTileIconBox"
                        android:background="@drawable/bg_tile_teal">

                        <ImageView
                            style="@style/ToolTileIcon"
                            android:src="@drawable/ic_pie_chart"
                            app:tint="@color/home_teal" />
                    </FrameLayout>

                    <TextView
                        style="@style/ToolTileTitle"
                        android:text="@string/tools_storage_analyzer" />

                    <TextView
                        style="@style/ToolTileDesc"
                        android:visibility="gone"

                        android:text="@string/tools_storage_analyzer_desc" />

                    <TextView
                        style="@style/ToolTileValue"
                        android:text="@string/tools_view_details"
                        android:visibility="gone"

                        android:textColor="@color/home_teal" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>

        <!-- ===== Security & Privacy ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/tools_section_security"
            android:textColor="@color/home_title"
            android:textSize="17sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardHealth"
                style="@style/ToolTileCard"
                android:background="@drawable/bg_back"

                android:layout_marginEnd="6dp">

                <LinearLayout style="@style/ToolTileContent">

                    <FrameLayout
                        style="@style/ToolTileIconBox"
                        android:background="@drawable/bg_tile_purple">

                        <ImageView
                            style="@style/ToolTileIcon"
                            android:src="@drawable/ic_shield"
                            app:tint="@color/home_primary" />
                    </FrameLayout>

                    <TextView
                        style="@style/ToolTileTitle"
                        android:text="@string/tools_vault_health" />

                    <TextView
                        style="@style/ToolTileDesc"
                        android:visibility="gone"

                        android:text="@string/tools_vault_health_desc" />

                    <TextView
                        style="@style/ToolTileValue"
                        android:text="@string/tools_status_secure"
                        android:textColor="@color/home_success" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <Space
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <!-- ===== Private Storage ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/tools_section_storage"
            android:textColor="@color/home_title"
            android:textSize="17sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardPrivateNotes"
                style="@style/ToolTileCard"
                android:background="@drawable/bg_back"

                android:layout_marginEnd="6dp">

                <LinearLayout style="@style/ToolTileContent">

                    <FrameLayout
                        style="@style/ToolTileIconBox"
                        android:background="@drawable/bg_tile_amber">

                        <ImageView
                            style="@style/ToolTileIcon"
                            android:src="@drawable/ic_note"
                            app:tint="@color/accent_amber" />
                    </FrameLayout>

                    <TextView
                        style="@style/ToolTileTitle"
                        android:text="@string/notes_title" />

                    <TextView
                        style="@style/ToolTileDesc"
                        android:visibility="gone"

                        android:text="@string/tools_private_notes_desc" />

                    <TextView
                        style="@style/ToolTileValue"
                        android:text="@string/tools_view_details"
                        android:textColor="@color/accent_amber" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cardPrivateDocuments"
                style="@style/ToolTileCard"
                android:background="@drawable/bg_back"

                android:layout_marginStart="6dp">

                <LinearLayout style="@style/ToolTileContent">

                    <FrameLayout
                        style="@style/ToolTileIconBox"
                        android:background="@drawable/bg_tile_blue">

                        <ImageView
                            style="@style/ToolTileIcon"
                            android:src="@drawable/ic_document"
                            app:tint="@color/accent_blue" />
                    </FrameLayout>

                    <TextView
                        style="@style/ToolTileTitle"
                        android:text="@string/documents_title" />

                    <TextView
                        style="@style/ToolTileDesc"
                        android:visibility="gone"

                        android:text="@string/tools_private_documents_desc" />

                    <TextView
                        style="@style/ToolTileValue"
                        android:text="@string/tools_view_details"
                        android:textColor="@color/accent_blue" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>


    </LinearLayout>
</androidx.core.widget.NestedScrollView>
