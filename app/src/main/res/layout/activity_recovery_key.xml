<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_padding"
        android:paddingTop="@dimen/space_xl"
        android:paddingEnd="@dimen/screen_padding"
        android:paddingBottom="@dimen/screen_padding">

        <FrameLayout
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_logo_circle"
            android:backgroundTint="@color/primary_container">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:contentDescription="@string/cd_card_icon"
                android:src="@drawable/ic_shield"
                app:tint="@color/primary" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_l"
            android:text="@string/recovery_title"
            android:textAppearance="@style/TextAppearance.App.Title" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_s"
            android:lineSpacingExtra="3dp"
            android:text="@string/recovery_subtitle"
            android:textAppearance="@style/TextAppearance.App.Body" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.App.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_l"
            app:cardBackgroundColor="@color/primary_container">

            <TextView
                android:id="@+id/tvRecoveryKey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:letterSpacing="0.08"
                android:padding="@dimen/space_l"
                android:textColor="@color/primary_dark"
                android:textSize="@dimen/text_heading"
                android:textStyle="bold"
                android:fontFamily="monospace"
                tools:text="ABCD-EFGH-JKMN-PQRS" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCopy"
            style="@style/Widget.App.Button.Outline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_m"
            app:icon="@drawable/ic_add"
            android:text="@string/recovery_copy" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_l"
            android:drawablePadding="@dimen/space_s"
            android:lineSpacingExtra="3dp"
            android:text="@string/recovery_warning"
            android:textColor="@color/accent_red"
            android:textSize="@dimen/text_caption" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="@dimen/space_xl" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContinue"
            style="@style/Widget.App.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/recovery_saved_confirm" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
