<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Semantic text-color theme attributes. Resolved per UI mode via DayNight
         color resources (values/colors.xml vs values-night/colors.xml), so layouts
         and text styles never hardcode a light- or dark-specific color. -->
    <attr name="colorTextPrimary" format="color" />
    <attr name="colorTextSecondary" format="color" />
    <attr name="colorTextTertiary" format="color" />
    <attr name="colorTextInverse" format="color" />
    <attr name="colorTextError" format="color" />
    <attr name="colorTextSuccess" format="color" />
    <attr name="colorTextWarning" format="color" />
</resources>
