<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Stats card helpers (Lock & Vault home) -->
    <style name="LvStatColumn">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center_horizontal</item>
        <item name="android:paddingStart">4dp</item>
        <item name="android:paddingEnd">4dp</item>
    </style>

    <style name="LvStatTile">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:background">@drawable/bg_lv_icon_tile</item>
    </style>

    <style name="LvStatIcon">
        <item name="android:layout_width">20dp</item>
        <item name="android:layout_height">20dp</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:contentDescription">@null</item>
    </style>

    <style name="LvStatValue">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:fontFamily">@font/inter_semi</item>
        <item name="fontFamily">@font/inter_semi</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:maxLines">1</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="LvStatLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">3dp</item>
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="fontFamily">@font/inter_medium</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">11.5sp</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="LvStatDivider">
        <item name="android:layout_width">1dp</item>
        <item name="android:layout_height">60dp</item>
        <item name="android:layout_gravity">center_vertical</item>
        <item name="android:background">@color/home_divider</item>
    </style>

    <!-- Vault quick actions -->
    <style name="LvQuickAction">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center_horizontal</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">?attr/selectableItemBackgroundBorderless</item>
    </style>

    <style name="LvQuickTile">
        <item name="android:layout_width">54dp</item>
        <item name="android:layout_height">54dp</item>
        <item name="android:background">@drawable/bg_lv_icon_tile</item>
    </style>

    <style name="LvQuickIcon">
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_height">24dp</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:contentDescription">@null</item>
        <item name="android:tint">@color/white</item>
    </style>

    <style name="LvQuickLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/home_subtitle</item>
        <item name="android:textSize">11.5sp</item>
    </style>

    <!-- Custom bottom-nav tab -->
    <style name="LvNavTab">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center_horizontal</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">?attr/selectableItemBackgroundBorderless</item>
    </style>

    <style name="LvNavIndicator">
        <item name="android:layout_width">26dp</item>
        <item name="android:layout_height">3dp</item>
        <item name="android:layout_marginBottom">7dp</item>
        <item name="android:background">@drawable/bg_lv_pill</item>
    </style>

    <style name="LvNavIcon">
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_height">24dp</item>
        <item name="android:contentDescription">@null</item>
    </style>

    <style name="LvNavLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">3dp</item>
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="android:textSize">11sp</item>
    </style>

</resources>
