<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme (DayNight: light here, dark in values-night/themes.xml). -->
    <style name="Base.Theme.AppLockPhotoValut" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_container</item>
        <item name="colorOnPrimaryContainer">@color/primary_dark</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>

        <!-- App-wide Inter typeface (weight-mapped family). -->
        <item name="android:fontFamily">@font/inter</item>
        <item name="fontFamily">@font/inter</item>

        <!-- Semantic text colors (DayNight via @color names). -->
        <item name="colorTextPrimary">@color/text_primary</item>
        <item name="colorTextSecondary">@color/text_secondary</item>
        <item name="colorTextTertiary">@color/text_tertiary</item>
        <item name="colorTextInverse">@color/text_inverse</item>
        <item name="colorTextError">@color/text_error</item>
        <item name="colorTextSuccess">@color/text_success</item>
        <item name="colorTextWarning">@color/text_warning</item>
    </style>

    <style name="Theme.AppLockPhotoValut" parent="Base.Theme.AppLockPhotoValut" />

    <!-- Splash uses brand color background -->
    <style name="Theme.AppLockPhotoValut.Splash" parent="Theme.AppLockPhotoValut">
        <item name="android:windowBackground">@color/primary</item>
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:navigationBarColor">@color/primary</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>
    </style>

    <!-- Inter weight styles. Each sets the matching Inter font file. -->
    <style name="TextAppearance.App.Regular" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">@font/inter_regular</item>
        <item name="fontFamily">@font/inter_regular</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">?attr/colorTextPrimary</item>
    </style>

    <style name="TextAppearance.App.Medium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="fontFamily">@font/inter_medium</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">?attr/colorTextPrimary</item>
    </style>

    <style name="TextAppearance.App.SemiBold" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">@font/inter_semi</item>
        <item name="fontFamily">@font/inter_semi</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">?attr/colorTextPrimary</item>
    </style>

    <style name="TextAppearance.App.Bold" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">@font/inter_bold</item>
        <item name="fontFamily">@font/inter_bold</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">?attr/colorTextPrimary</item>
    </style>

    <!-- Text styles — colors come from theme attributes so they adapt to light/dark. -->
    <style name="TextAppearance.App.Display" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">?attr/colorTextPrimary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/text_display</item>
    </style>

    <style name="TextAppearance.App.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">?attr/colorTextPrimary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/text_title</item>
    </style>

    <style name="TextAppearance.App.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">?attr/colorTextSecondary</item>
        <item name="android:textSize">@dimen/text_body</item>
    </style>

    <style name="TextAppearance.App.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">?attr/colorTextTertiary</item>
        <item name="android:textSize">@dimen/text_caption</item>
    </style>

    <style name="TextAppearance.App.Error" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">?attr/colorTextError</item>
        <item name="android:textSize">@dimen/text_caption</item>
    </style>

    <style name="TextAppearance.App.Success" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">?attr/colorTextSuccess</item>
        <item name="android:textSize">@dimen/text_caption</item>
    </style>

    <style name="TextAppearance.App.Warning" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">?attr/colorTextWarning</item>
        <item name="android:textSize">@dimen/text_caption</item>
    </style>

    <!-- Primary button -->
    <style name="Widget.App.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="cornerRadius">@dimen/radius_m</item>
    </style>

    <!-- Outlined / text button -->
    <style name="Widget.App.Button.Outline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/primary</item>
        <item name="strokeColor">@color/primary</item>
        <item name="cornerRadius">@dimen/radius_m</item>
    </style>

    <style name="Widget.App.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="Widget.App.Chip.SoftClose" parent="Widget.Material3.Chip.Filter">
        <item name="android:minHeight">44dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">normal</item>
        <item name="checkedIconVisible">false</item>
        <item name="chipBackgroundColor">@color/tile_gray_bg</item>
        <item name="chipCornerRadius">22dp</item>
        <item name="chipMinHeight">44dp</item>
        <item name="chipStartPadding">18dp</item>
        <item name="chipEndPadding">10dp</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="closeIconVisible">false</item>
        <item name="textEndPadding">0dp</item>
        <item name="textStartPadding">0dp</item>
    </style>

    <!-- Numeric keypad key (shared by digit TextViews and icon ImageViews) -->
    <style name="KeypadKey">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">@dimen/keypad_button_size</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">@dimen/keypad_text_size</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">normal</item>
        <item name="android:background">?attr/selectableItemBackgroundBorderless</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:scaleType">center</item>
    </style>

    <!-- Settings -->
    <style name="SettingsSectionHeader">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">@dimen/space_l</item>
        <item name="android:layout_marginBottom">@dimen/space_s</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.04</item>
    </style>

    <style name="SettingsRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:minHeight">64dp</item>
        <item name="android:padding">@dimen/space_m</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="SettingsRowIcon">
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_height">24dp</item>
        <item name="android:layout_gravity">center_vertical</item>
        <item name="android:contentDescription">@string/cd_card_icon</item>
    </style>

    <style name="SettingsRowText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginStart">@dimen/space_m</item>
        <item name="android:layout_marginEnd">@dimen/space_s</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="SettingsRowTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="SettingsRowDesc">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">2dp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">@dimen/text_caption</item>
    </style>

    <style name="SettingsRowValue">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_gravity">center_vertical</item>
        <item name="android:layout_marginEnd">@dimen/space_s</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="SettingsRowTrailingIcon">
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_height">24dp</item>
        <item name="android:layout_gravity">center_vertical</item>
        <item name="android:contentDescription">@string/cd_card_icon</item>
    </style>

    <style name="SettingsDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:layout_marginStart">56dp</item>
        <item name="android:background">@color/divider</item>
    </style>

    <!-- Full-screen viewer bottom action button -->
    <style name="ViewerBottomAction">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">@dimen/viewer_action_size</item>
        <item name="android:layout_weight">1</item>
        <item name="android:background">?attr/selectableItemBackgroundBorderless</item>
        <item name="android:tint">@color/white</item>
        <item name="android:scaleType">center</item>
    </style>

    <!-- Calculator lock (Phase 6) -->
    <style name="CalculatorRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
    </style>

    <style name="CalculatorKey">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">@dimen/keypad_button_size</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">@dimen/keypad_text_size</item>
        <item name="android:textColor">@color/calculator_text</item>
        <item name="android:background">?attr/selectableItemBackgroundBorderless</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="CalculatorKey.Accent">
        <item name="android:textColor">@color/calculator_accent</item>
    </style>

    <style name="CalculatorKey.Equals">
        <item name="android:layout_weight">2</item>
        <item name="android:textColor">@color/calculator_accent</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Troubleshooting checklist row -->
    <style name="TroubleshootRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingTop">@dimen/space_s</item>
        <item name="android:paddingBottom">@dimen/space_s</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:drawablePadding">@dimen/space_m</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_body</item>
    </style>

    <!-- Card -->
    <style name="Widget.App.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/tile_gray_bg</item>
        <item name="cardCornerRadius">@dimen/radius_l</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/card_stroke</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <!-- Private Camera capture-result actions -->
    <style name="CaptureResultAction">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
        <item name="android:background">?attr/selectableItemBackgroundBorderless</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>

    <style name="CaptureResultActionIcon">
        <item name="android:layout_width">26dp</item>
        <item name="android:layout_height">26dp</item>
        <item name="tint">@color/white</item>
    </style>

    <style name="CaptureResultActionLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">6dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">12sp</item>
    </style>

    <!-- Private Camera settings rows -->
    <style name="CameraSettingChoiceRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:paddingTop">@dimen/space_m</item>
        <item name="android:paddingBottom">@dimen/space_m</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_body</item>
    </style>

    <style name="CameraSettingSwitchRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingTop">@dimen/space_m</item>
        <item name="android:paddingBottom">@dimen/space_m</item>
    </style>

    <style name="CameraSettingSwitchLabel">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_body</item>
    </style>

    <!-- Premium badge chip (Phase 11) -->
    <style name="PremiumBadge">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/bg_premium_badge</item>
        <item name="android:paddingStart">10dp</item>
        <item name="android:paddingEnd">10dp</item>
        <item name="android:paddingTop">3dp</item>
        <item name="android:paddingBottom">3dp</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
