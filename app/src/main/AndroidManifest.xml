<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-feature
        android:name="android.hardware.camera.front"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.camera.any"
        android:required="false" />

    <!-- Resolve only launchable apps (no QUERY_ALL_PACKAGES). -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <application
        android:name=".App"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppLockPhotoValut"
        tools:targetApi="31">

        <activity
            android:name=".features.splash.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.AppLockPhotoValut.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>


        <!-- Ported language + onboarding flow -->
        <activity
            android:name=".features.ob.OnBoardingActivity"
            android:exported="false" />
        <activity
            android:name="com.wastickers.romantic.stickers.loveromance.ui.language.LanguageActivity"
            android:exported="false" />
        <activity
            android:name="com.wastickers.romantic.stickers.loveromance.ui.language.EnglishActivity"
            android:exported="false" />
        <activity
            android:name="com.wastickers.romantic.stickers.loveromance.ui.language.HindiActivity"
            android:exported="false" />

        <activity
            android:name=".features.auth.ChooseUnlockMethodActivity"
            android:exported="false" />

        <activity
            android:name=".features.auth.CreatePinActivity"
            android:exported="false" />

        <activity
            android:name=".features.auth.ConfirmPinActivity"
            android:exported="false" />

        <activity
            android:name=".features.auth.RecoveryKeyActivity"
            android:exported="false" />

        <activity
            android:name=".features.auth.BiometricSetupActivity"
            android:exported="false" />

        <activity
            android:name=".features.auth.UnlockActivity"
            android:exported="false" />

        <activity
            android:name=".features.auth.PatternUnlockActivity"
            android:exported="false" />

        <activity
            android:name=".features.auth.PatternSetupActivity"
            android:exported="false" />

        <activity
            android:name=".features.auth.ChangePinActivity"
            android:exported="false" />

        <activity
            android:name=".features.auth.ForgotPinActivity"
            android:exported="false" />

        <activity
            android:name=".features.auth.VerifyMasterActivity"
            android:exported="false" />

        <activity
            android:name=".features.home.MainActivity"
            android:exported="false" />

        <activity
            android:name=".features.settings.SettingsActivity"
            android:exported="false" />

        <activity
            android:name=".features.vault.AlbumsActivity"
            android:exported="false" />

        <activity
            android:name=".features.vault.MediaGridActivity"
            android:exported="false" />

        <activity
            android:name=".features.importmedia.ImportProgressActivity"
            android:exported="false" />

        <activity
            android:name=".features.vault.EncryptionMigrationActivity"
            android:exported="false" />

        <!-- Private Camera (Phase 9) -->
        <activity
            android:name=".features.camera.PrivateCameraActivity"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.AppLockPhotoValut" />

        <activity
            android:name=".features.premium.notes.PrivateNotesActivity"
            android:exported="false" />

        <activity
            android:name=".features.premium.notes.PrivateNoteEditorActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".features.documents.PrivateDocumentsActivity"
            android:exported="false" />

        <activity
            android:name=".features.documents.cards.AddEditDocumentCardActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".features.documents.cards.DocumentCardDetailActivity"
            android:exported="false" />

        <!-- Premium cleanup tools -->
        <activity
            android:name=".features.cleanup.storage.StorageAnalyzerActivity"
            android:exported="false" />

        <activity
            android:name=".features.cleanup.health.VaultHealthActivity"
            android:exported="false" />

        <activity
            android:name=".features.cleanup.duplicates.DuplicateFinderActivity"
            android:exported="false" />

        <activity
            android:name=".features.cleanup.largefiles.LargeFilesActivity"
            android:exported="false" />

        <activity
            android:name=".features.cleanup.smartcleanup.SmartCleanupActivity"
            android:exported="false" />

        <activity
            android:name=".features.vault.photo.PhotoViewerActivity"
            android:exported="false"
            android:theme="@style/Theme.AppLockPhotoValut" />

        <activity
            android:name=".features.vault.video.VideoPlayerActivity"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:exported="false"
            android:theme="@style/Theme.AppLockPhotoValut" />

        <!-- App Lock (Phase 5) -->
        <activity
            android:name=".features.applock.AppLockActivity"
            android:exported="false" />

        <activity
            android:name=".features.applock.apps.AppLockAppsActivity"
            android:exported="false" />

        <activity
            android:name=".features.applock.settings.AppLockSettingsActivity"
            android:exported="false" />

        <activity
            android:name=".features.applock.theme.LockThemePickerActivity"
            android:exported="false" />

        <activity
            android:name=".features.applock.troubleshooting.AppLockTroubleshootingActivity"
            android:exported="false" />

        <activity
            android:name=".features.applock.suggested.SuggestedAppsActivity"
            android:exported="false" />

        <activity
            android:name=".features.permissions.AppLockPermissionActivity"
            android:exported="false"
            android:launchMode="singleTop" />

        <activity
            android:name=".features.applock.overlay.AppLockOverlayActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:launchMode="singleTask"
            android:taskAffinity=".applock.overlay"
            android:theme="@style/Theme.AppLockPhotoValut" />

        <service
            android:name=".core.applock.service.AppLockMonitorService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="App Lock monitors the current foreground app locally to show the lock screen for user-selected apps. No usage data leaves the device." />
        </service>

        <receiver
            android:name=".core.applock.receiver.BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".core.applock.receiver.PackageChangeReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.PACKAGE_ADDED" />
                <action android:name="android.intent.action.PACKAGE_REMOVED" />
                <action android:name="android.intent.action.PACKAGE_FULLY_REMOVED" />
                <data android:scheme="package" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
